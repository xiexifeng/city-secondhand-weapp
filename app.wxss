/**app.wxss**/
/* 全局颜色定义 */
:root {
  --primary-color: #1890ff;
  --success-color: #52c41a;
  --warning-color: #faad14;
  --danger-color: #f5222d;
  --text-color: #333;
  --text-color-secondary: #666;
  --border-color: #e8e8e8;
  --bg-color: #f5f5f5;
}

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
    'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
    sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  color: #333;
  font-size: 28rpx;
  line-height: 1.5;
  margin: 0;
  padding: 0;
}

/* 容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background-color: #f5f5f5;
}

.content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

/* 文本样式 */
.text-primary {
  color: #1890ff;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-danger {
  color: #f5222d;
}

.text-secondary {
  color: #666;
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: bold;
}

/* 间距 */
.mt-8 {
  margin-top: 16rpx;
}

.mt-16 {
  margin-top: 32rpx;
}

.mb-8 {
  margin-bottom: 16rpx;
}

.mb-16 {
  margin-bottom: 32rpx;
}

.p-8 {
  padding: 16rpx;
}

.p-16 {
  padding: 32rpx;
}

/* 按钮样式 */
.btn {
  padding: 16rpx 24rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  cursor: pointer;
  text-align: center;
  display: inline-block;
}

.btn-primary {
  background-color: #1890ff;
  color: white;
}

.btn-primary:active {
  background-color: #0050b3;
  opacity: 0.9;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #e8e8e8;
}

.btn-secondary:active {
  background-color: #e8e8e8;
}

.btn-danger {
  background-color: #f5222d;
  color: white;
}

.btn-danger:active {
  background-color: #d9001b;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

/* 输入框样式 */
input, textarea {
  padding: 12rpx 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 6rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

input:focus, textarea:focus {
  border-color: #1890ff;
  background-color: white;
}

/* 图片样式 */
image {
  display: block;
}

/* 列表样式 */
.list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.list-item {
  background-color: white;
  padding: 16rpx;
  border-radius: 8rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 网格布局 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.grid-item {
  background-color: white;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60rpx 20rpx;
  color: #999;
  text-align: center;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 响应式 */
@media (min-width: 768px) {
  .grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
