/* 举报模态框样式 */
.report-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.report-modal-content {
  background-color: white;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.report-modal-header {
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.report-modal-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #dc2626;
  margin-bottom: 4rpx;
}

.report-modal-subtitle {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
  text-align: center;
}

.report-modal-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 32rpx;
  color: #9ca3af;
  cursor: pointer;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background-color 0.2s;
}

.report-modal-close:hover {
  background-color: #f3f4f6;
}

.report-form {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.reason-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reason-option {
  padding: 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.2s;
}

.reason-option:hover {
  border-color: #f3f4f6;
  background-color: #f9fafb;
}

.reason-option.selected {
  border-color: #dc2626;
  background-color: #fee2e2;
}

.reason-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.reason-desc {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1f2937;
  resize: vertical;
}

.form-textarea::placeholder {
  color: #9ca3af;
}

.textarea-counter {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  text-align: right;
  margin-top: 4rpx;
}

.upload-section {
  margin-top: 8rpx;
}

.upload-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border: 2rpx dashed #e5e7eb;
  border-radius: 8rpx;
  background-color: #f9fafb;
  cursor: pointer;
  transition: all 0.2s;
}

.upload-btn:hover {
  border-color: #d1d5db;
  background-color: #f3f4f6;
}

.upload-icon {
  font-size: 32rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #6b7280;
}

/* 已上传图片预览区样式 */
.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.uploaded-image-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e5e7eb;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.remove-image-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background-color: rgba(0, 0, 0, 0.7);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  cursor: pointer;
  z-index: 10;
}

.remove-image-btn:hover {
  background-color: rgba(0, 0, 0, 0.9);
}

.privacy-note {
  padding: 16rpx;
  background-color: #f3f4f6;
  border-radius: 8rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.privacy-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.privacy-text {
  flex: 1;
  font-size: 20rpx;
  color: #6b7280;
  line-height: 1.5;
}

.form-actions {
  display: flex;
  gap: 12rpx;
}

.cancel-btn,
.submit-btn {
  flex: 1;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.cancel-btn {
  background-color: #f3f4f6;
  color: #6b7280;
  border: 1rpx solid #e5e7eb;
}

.cancel-btn:hover {
  background-color: #e5e7eb;
}

.submit-btn {
  background-color: #dc2626;
  color: white;
  border: none;
}

.submit-btn:hover:not(:disabled) {
  background-color: #b91c1c;
}

.submit-btn:disabled {
  background-color: #fecaca;
  color: #fca5a5;
  cursor: not-allowed;
}