page {
  background-color: #ffffff;
}

.login-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  background-color: #ffffff;
  overflow: hidden;
}

/* Background */
.background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 50%, #0ea5e9 100%);
  z-index: 0;
}

/* Login Content */
.login-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 40rpx 24rpx;
}

/* Logo Section */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
  margin-bottom: 50rpx;
  animation: slideDown 0.6s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.logo-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.logo-circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(16, 185, 129, 0.25);
  position: relative;
  overflow: hidden;
}

.logo-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.logo-text {
  font-size: 70rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.logo-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid rgba(16, 185, 129, 0.2);
  animation: spin 8s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.app-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 8rpx;
  display: block;
  letter-spacing: 1rpx;
}

.app-slogan {
  font-size: 18rpx;
  color: #9ca3af;
  display: block;
  font-weight: 500;
}

/* Login Methods */
.login-methods {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 12rpx;
}

/* Login Option */
.login-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 20rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slideUp 0.5s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-option:active {
  background-color: #f9fafb;
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.08);
}

.wechat-option {
  border: 2rpx solid #10b981;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(5, 150, 105, 0.05) 100%);
}

.sms-option {
  border: 2rpx solid #0ea5e9;
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.05) 0%, rgba(2, 132, 199, 0.05) 100%);
}

.option-icon {
  font-size: 44rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  background-color: #f3f4f6;
  border-radius: 12rpx;
}

.option-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.option-title {
  font-size: 20rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  margin-bottom: 4rpx;
}

.option-desc {
  font-size: 16rpx;
  color: #9ca3af;
  display: block;
  font-weight: 500;
}

.option-arrow {
  font-size: 28rpx;
  color: #d1d5db;
  flex-shrink: 0;
  transition: all 0.2s;
}

.login-option:active .option-arrow {
  color: #10b981;
  transform: translateX(4rpx);
}

/* SMS Form */
.sms-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  animation: slideUp 0.4s ease-out;
}

.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  gap: 12rpx;
}

.back-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f3f4f6;
  border-radius: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.back-btn:active {
  background-color: #e5e7eb;
  transform: scale(0.95);
}

.back-arrow {
  display: block;
}

.form-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  flex: 1;
  text-align: center;
}

.form-header-spacer {
  width: 40rpx;
}

/* Form Group */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  transition: all 0.2s;
}

.form-input-wrapper:focus-within {
  border-color: #10b981;
  background-color: #ffffff;
  box-shadow: 0 0 0 3rpx rgba(16, 185, 129, 0.1);
}

.form-input-icon {
  font-size: 20rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  background: transparent;
  border: none;
  font-size: 18rpx;
  color: #1f2937;
  padding: 0;
}

.form-input::placeholder {
  color: #d1d5db;
}

/* Code Input Group */
.code-input-wrapper {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.code-input-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  transition: all 0.2s;
}

.code-input-left:focus-within {
  border-color: #10b981;
  background-color: #ffffff;
  box-shadow: 0 0 0 3rpx rgba(16, 185, 129, 0.1);
}

.code-input {
  flex: 1;
  background: transparent;
  border: none;
  font-size: 18rpx;
  color: #1f2937;
  padding: 0;
  letter-spacing: 4rpx;
}

.code-input::placeholder {
  color: #d1d5db;
  letter-spacing: 0;
}

.send-code-btn {
  padding: 14rpx 16rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
  border-radius: 12rpx;
  font-size: 16rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  transition: all 0.2s;
  min-width: 100rpx;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

.send-code-btn:active {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(16, 185, 129, 0.3);
}

.send-code-btn.disabled {
  background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%);
  color: white;
  cursor: not-allowed;
  box-shadow: none;
}

/* Login Button */
.login-btn {
  padding: 16rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-top: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.25);
}

.login-btn:active {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 28rpx rgba(16, 185, 129, 0.35);
}

.login-btn.loading {
  opacity: 0.8;
  pointer-events: none;
}

/* Agreement Section */
.agreement-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  margin-top: auto;
}

.agreement-text {
  font-size: 16rpx;
  color: #9ca3af;
  display: block;
  font-weight: 500;
}

.agreement-links {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.agreement-link {
  font-size: 16rpx;
  color: #10b981;
  text-decoration: underline;
  display: inline-block;
  font-weight: 600;
  transition: all 0.2s;
}

.agreement-link:active {
  opacity: 0.7;
}

.agreement-separator {
  font-size: 16rpx;
  color: #9ca3af;
  display: inline-block;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  width: 100%;
  background-color: white;
  border-radius: 20rpx 20rpx 0 0;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
  animation: slideUpModal 0.3s ease-out;
}

@keyframes slideUpModal {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.modal-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  flex: 1;
}

.modal-close {
  font-size: 28rpx;
  color: #9ca3af;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.modal-close:active {
  color: #6b7280;
  transform: scale(0.9);
}

.modal-body {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.agreement-content {
  font-size: 16rpx;
  color: #6b7280;
  line-height: 1.8;
  display: block;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.modal-footer {
  padding: 16rpx 24rpx 24rpx;
  border-top: 1rpx solid #e5e7eb;
}

.modal-btn {
  padding: 14rpx 16rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 700;
  text-align: center;
  transition: all 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

.modal-btn:active {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(16, 185, 129, 0.3);
}
