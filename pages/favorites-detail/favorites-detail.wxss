/* pages/favorites-detail/favorites-detail.wxss */

page {
  background-color: #f3f4f6;
}

.favorites-detail-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* Tab Bar */
.tab-bar {
  display: flex;
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 9;
}

.tab-item {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  border-bottom: 2rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.active {
  border-bottom-color: #0ea5e9;
}

.tab-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #9ca3af;
  transition: all 0.2s;
}

.tab-item.active .tab-text {
  color: #0ea5e9;
}

/* Favorites Section */
.favorites-section {
  padding: 16rpx;
  flex: 1;
}

/* Favorites List */
.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* Item Card */
.item-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: visible;
  position: relative;
  margin-bottom: 12rpx;
}

/* Item View */
.item-view {
  padding: 12rpx;
}

.item-header {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
}

.item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.item-date {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.item-badges {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.item-price {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #f97316;
}

.exchange-badge {
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
  background-color: #dcfce7;
  color: #166534;
  margin-left: 8rpx;
}

.item-stats {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.stat-item {
  display: inline-block;
}

.item-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f3f4f6;
}

/* Wish Card */
.wish-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: visible;
  position: relative;
  margin-bottom: 12rpx;
}

/* Wish View */
.wish-view {
  padding: 12rpx;
}

.wish-header {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.wish-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.wish-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.wish-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.wish-description {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.4;
}

.wish-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.wish-date {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.wish-stats {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.wish-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 12rpx;
  border-top: 1rpx solid #f3f4f6;
}

/* Favorite Action */
.favorite-action {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background-color: #fef2f2;
  border: 1rpx solid #fca5a5;
  cursor: pointer;
  transition: all 0.2s;
}

.favorite-action:active {
  background-color: #fecaca;
}

.favorite-action-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #ef4444;
}