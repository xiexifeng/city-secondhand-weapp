/* pages/profile/profile.wxss */

page {
  background-color: #f3f4f6;
}

.profile-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* User Header */
.user-header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 16rpx;
}

.header-top {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 12rpx;
}

.theme-switcher {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background-color: #f3f4f6;
  cursor: pointer;
  transition: all 0.2s;
}

.theme-switcher:active {
  background-color: #e5e7eb;
}

.theme-icon {
  font-size: 20rpx;
}

/* User Info */
.user-info {
  display: flex;
  gap: 12rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10b981, #059669);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-text {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.level-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.level-badge.new {
  background-color: #3b82f6;
}

.level-badge.active {
  background-color: #22c55e;
}

.level-badge.vip {
  background-color: #8b5cf6;
}

/* User Details */
.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
}

.level-label {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-weight: 600;
}

.level-label.new {
  background-color: #3b82f6;
  color: white;
}

.level-label.active {
  background-color: #22c55e;
  color: white;
}

.level-label.vip {
  background-color: #8b5cf6;
  color: white;
}

.user-status {
  font-size: 20rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.user-stats {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: #9ca3af;
}

.stat-item {
  display: inline-block;
}

.stat-separator {
  display: inline-block;
}

/* Publish Data Section */
.publish-data-section {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.data-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  transition: all 0.2s;
}

.data-card:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-icon {
  font-size: 20rpx;
}

.card-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.card-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #0ea5e9;
}

.card-count.emerald {
  color: #10b981;
}

/* Data Grid */
.data-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.data-item {
  padding: 12rpx;
  border-radius: 8rpx;
  text-align: center;
  background-color: #f3f4f6;
  transition: all 0.2s;
}

.data-item:active {
  background-color: #e5e7eb;
}

.data-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #0ea5e9;
  margin-bottom: 4rpx;
}

.data-item:nth-child(2) .data-value {
  color: #dc2626;
}

.data-item:nth-child(3) .data-value {
  color: #f59e0b;
}

.data-label {
  font-size: 20rpx;
  color: #9ca3af;
}

/* Tasks Section */
.tasks-section {
  padding: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-icon {
  font-size: 20rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.view-all {
  font-size: 20rpx;
  color: #0ea5e9;
  font-weight: 600;
}

/* Tasks List */
.tasks-list {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.task-item {
  padding: 12rpx;
  border-radius: 8rpx;
  background-color: #f9fafb;
  border: 1rpx solid #f3f4f6;
}

.task-item.completed {
  background-color: #f0fdf4;
  border-color: #dcfce7;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.task-info {
  flex: 1;
}

.task-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.task-description {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

.task-reward {
  font-size: 20rpx;
  font-weight: bold;
  color: #0ea5e9;
}

/* Task Progress */
.task-progress {
  margin-top: 8rpx;
}

.progress-bar {
  width: 100%;
  height: 3rpx;
  background-color: #e5e7eb;
  border-radius: 2rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0ea5e9, #10b981);
  border-radius: 2rpx;
  transition: width 0.6s ease;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  margin-top: 4rpx;
}

.progress-count {
  font-size: 20rpx;
  color: #9ca3af;
}

/* Task Completed */
.task-completed {
  font-size: 20rpx;
  color: #10b981;
  font-weight: bold;
}

/* Stats Grid */
.stats-grid {
  padding: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.stat-card {
  border-radius: 12rpx;
  padding: 16rpx;
  transition: all 0.2s;
}

.stat-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.points-card {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border: 1rpx solid #fcd34d;
}

.favorites-card {
  background: linear-gradient(135deg, #fee2e2, #fecaca);
  border: 1rpx solid #fca5a5;
}

.stat-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.stat-card-icon {
  font-size: 20rpx;
}

.stat-card-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
}

.stat-card-value {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #f59e0b;
}

.points-card .stat-number {
  color: #d97706;
}

.favorites-card .stat-number {
  color: #dc2626;
}

.stat-unit {
  font-size: 20rpx;
  color: #9ca3af;
}

.stat-card-desc {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

/* Discover Section */
.discover-section {
  padding: 16rpx;
  background: linear-gradient(135deg, #fef3c7, #fee2e2);
  border: 1rpx solid #fcd34d;
  border-radius: 12rpx;
  margin: 0 16rpx;
}

.discover-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.discover-icon {
  font-size: 20rpx;
}

.discover-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

/* Discover List */
.discover-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.discover-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.discover-item:active {
  background-color: rgba(255, 255, 255, 0.5);
}

.discover-icon-item {
  font-size: 20rpx;
}

.discover-label-item {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
  color: #1f2937;
}

.discover-arrow {
  font-size: 24rpx;
  color: #9ca3af;
}

/* Settings Section */
.settings-section {
  padding: 16rpx;
  margin-top: 16rpx;
}

.settings-section-title {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #9ca3af;
  margin-bottom: 8rpx;
  padding: 0 16rpx;
}

.settings-list {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: hidden;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
  transition: all 0.2s;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background-color: #f9fafb;
}

.settings-item-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.settings-icon {
  font-size: 20rpx;
}

.settings-icon.logout {
  color: #dc2626;
}

.settings-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.settings-text.logout {
  color: #dc2626;
}

.settings-arrow {
  font-size: 20rpx;
  color: #9ca3af;
}
