<!--pages/edit-profile/edit-profile.wxml-->
<view class="edit-profile-container">
  <!-- Header -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-arrow">‹</text>
      <text class="header-title">编辑个人信息</text>
    </view>
  </view>

  <!-- Avatar Card -->
  <view class="avatar-card">
    <view class="avatar-container">
      <view class="avatar">
        <text class="avatar-text">U</text>
      </view>
      <view class="avatar-action" bindtap="changeAvatar">
        <text class="action-icon">📷</text>
        <text class="action-text">更换头像</text>
      </view>
    </view>
  </view>

  <!-- Form -->
  <view class="form-section">
    <!-- Nickname -->
    <view class="form-group">
      <text class="form-label">昵称</text>
      <input class="form-input" value="{{profile.nickname}}" bindinput="handleChange" data-field="nickname" placeholder="请输入昵称" maxlength="20"></input>
    </view>

    <!-- Bio -->
    <view class="form-group">
      <text class="form-label">个人简介</text>
      <textarea class="form-textarea" value="{{profile.bio}}" bindinput="handleChange" data-field="bio" placeholder="介绍一下你自己吧" maxlength="100"></textarea>
      <text class="char-count">{{profile.bio.length}}/100</text>
    </view>

    <!-- Location -->
    <view class="form-group">
      <text class="form-label">所在地区</text>
      <view class="location-input" bindtap="selectLocation">
        <text class="location-text">{{profile.location || '请选择地区'}}</text>
        <text class="location-arrow">›</text>
      </view>
    </view>

    <!-- Contact Info -->
    <view class="form-group">
      <text class="form-label">联系方式</text>
      
      <view class="contact-item">
        <text class="contact-label">手机号</text>
        <input class="contact-input" type="tel" value="{{profile.phone}}" bindinput="handleChange" data-field="phone" placeholder="请输入手机号"></input>
      </view>

      <view class="contact-item">
        <text class="contact-label">邮箱</text>
        <input class="contact-input" type="email" value="{{profile.email}}" bindinput="handleChange" data-field="email" placeholder="请输入邮箱"></input>
      </view>
    </view>

    <!-- Tips -->
    <view class="tips-card">
      <text class="tips-icon">ℹ️</text>
      <text class="tips-text">完整的个人信息可以帮助其他用户更好地了解你，提高交易成功率。</text>
    </view>

    <!-- Save Button -->
    <view class="button-group">
      <view class="btn btn-save" bindtap="handleSave">保存修改</view>
      <view class="btn btn-cancel" bindtap="goBack">取消</view>
    </view>
  </view>
</view>
