page {
  background-color: #f3f4f6;
}

.privacy-policy-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f3f4f6;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

/* Content */
.content {
  flex: 1;
  padding: 24rpx 16rpx;
}

/* Section */
.section {
  background-color: white;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

.section-content {
  display: block;
  font-size: 24rpx;
  color: var(--text-color-secondary);
  line-height: 1.8;
}

/* Footer Spacing */
.footer-spacing {
  height: 40rpx;
}

/* Table Styles */
.table-container {
  width: 100%;
  margin: 16rpx 0;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  overflow: hidden;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #e5e7eb;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row.header {
  background-color: #f9fafb;
  font-weight: 600;
}

.table-cell {
  flex: 1;
  padding: 12rpx 8rpx;
  font-size: 22rpx;
  color: var(--text-color-secondary);
  text-align: center;
  word-break: break-word;
}

.table-row.header .table-cell {
  color: var(--text-color);
  font-weight: 600;
}
