/* pages/points-detail/points-detail.wxss */

page {
  background-color: #f3f4f6;
}

.points-detail-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: white;
  padding: 16rpx;
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background-color: #f3f4f6;
  cursor: pointer;
  transition: all 0.2s;
}

.header-left:active {
  background-color: #e5e7eb;
}

.back-icon {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
}

.header-right {
  width: 40rpx;
}

/* Points Summary */
.points-summary {
  padding: 16rpx;
}

.summary-card {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border: 1rpx solid #fcd34d;
  border-radius: 12rpx;
  padding: 20rpx;
  transition: all 0.2s;
}

.summary-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.summary-icon {
  font-size: 24rpx;
}

.summary-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
}

.summary-value {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.summary-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #d97706;
}

.summary-unit {
  font-size: 24rpx;
  color: #9ca3af;
}

.summary-desc {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

/* Points History */
.points-history {
  padding: 16rpx;
  flex: 1;
}

.section-header {
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

/* History List */
.history-list {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
  transition: all 0.2s;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background-color: #f9fafb;
}

.history-item-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.history-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.history-icon.earn {
  background-color: #f0fdf4;
  color: #10b981;
}

.history-icon.spend {
  background-color: #fef2f2;
  color: #ef4444;
}

.history-info {
  flex: 1;
}

.history-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.history-time {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

.history-item-right {
  flex-shrink: 0;
}

.history-points {
  font-size: 24rpx;
  font-weight: bold;
}

.history-points.earn {
  color: #10b981;
}

.history-points.spend {
  color: #ef4444;
}