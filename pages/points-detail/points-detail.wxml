<!--pages/points-detail/points-detail.wxml-->
<view class="points-detail-container">
  <!-- Header -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-center">
      <text class="header-title">积分明细</text>
    </view>
    <view class="header-right"></view>
  </view>

  <!-- Points Summary -->
  <view class="points-summary">
    <view class="summary-card">
      <view class="summary-header">
        <text class="summary-icon">⚡</text>
        <text class="summary-label">当前积分</text>
      </view>
      <view class="summary-value">
        <text class="summary-number">{{totalPoints}}</text>
        <text class="summary-unit">积分</text>
      </view>
      <text class="summary-desc">本月获得 +45 积分</text>
    </view>
  </view>

  <!-- Points History -->
  <view class="points-history">
    <view class="section-header">
      <text class="section-title">积分记录</text>
    </view>

    <view class="history-list">
      <view wx:for="{{pointsHistory}}" wx:key="id" class="history-item">
        <view class="history-item-left">
          <view class="history-icon {{item.type}}">
            {{item.icon}}
          </view>
          <view class="history-info">
            <text class="history-title">{{item.title}}</text>
            <text class="history-time">{{item.time}}</text>
          </view>
        </view>
        <view class="history-item-right">
          <text class="history-points {{item.type}}">{{item.points > 0 ? '+' : ''}}{{item.points}} 积分</text>
        </view>
      </view>
    </view>
  </view>
</view>