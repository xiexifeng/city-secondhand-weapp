/* pages/wish-detail/wish-detail.wxss */

page {
  background-color: #f3f4f6;
}

.wish-detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f3f4f6;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  padding-top: 32rpx;
  z-index: 10;
  position: sticky;
  top: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
}

/* Content Scroll */
.content-scroll {
  flex: 1;
  overflow-y: auto;
}

.content {
  padding: 16rpx;
}

/* Wish Header */
.wish-header {
  background-color: white;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.wish-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.category-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #d1fae5;
  color: #065f46;
  border-radius: 20rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.verified-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #dbeafe;
  color: #0c4a6e;
  border-radius: 20rpx;
  font-size: 18rpx;
  font-weight: 700;
}

/* Section */
.section {
  background-color: white;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  margin-bottom: 16rpx;
}

.description-text {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
  display: block;
}

.budget-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #f59e0b;
  display: block;
}

/* Meta Info */
.meta-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-label {
  font-size: 20rpx;
  color: #6b7280;
  min-width: 80rpx;
  font-weight: 500;
}

.meta-value {
  font-size: 22rpx;
  color: #1f2937;
  font-weight: 600;
}

/* Publisher Card */
.publisher-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.publisher-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ec4899 0%, #a855f7 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.publisher-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.publisher-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.publisher-status {
  font-size: 18rpx;
  color: #9ca3af;
  display: block;
  margin-top: 4rpx;
}

.report-btn {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: white;
  border-radius: 8rpx;
  font-size: 18rpx;
}

/* Safety Tips */
.safety-tips {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background-color: #eff6ff;
  border-left: 4rpx solid #0ea5e9;
  padding: 12rpx 16rpx;
  border-radius: 4rpx;
}

.tips-title {
  font-size: 20rpx;
  font-weight: 700;
  color: #0369a1;
  display: block;
}

.tips-text {
  font-size: 18rpx;
  color: #0369a1;
  display: block;
  line-height: 1.6;
}

/* Action Bar */
.action-bar {
  background-color: white;
  border-top: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.contact-btn {
  background-color: #10b981;
  color: white;
}

.contact-btn:active {
  background-color: #059669;
  transform: scale(0.98);
}

.action-icon {
  font-size: 16rpx;
}

.action-text {
  font-size: 14rpx;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  background-color: white;
  border-radius: 16rpx 16rpx 0 0;
  padding: 24rpx 16rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-title {
  font-size: 18rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 16rpx;
}

.report-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.report-option {
  padding: 12rpx 16rpx;
  background-color: #f3f4f6;
  border-radius: 8rpx;
  font-size: 14rpx;
  color: #1f2937;
  transition: all 0.2s;
}

.report-option:active {
  background-color: #e5e7eb;
  transform: scale(0.98);
}

.modal-close {
  padding: 12rpx 16rpx;
  background-color: #f3f4f6;
  border-radius: 8rpx;
  font-size: 14rpx;
  color: #6b7280;
  text-align: center;
  font-weight: 600;
  transition: all 0.2s;
}

.modal-close:active {
  background-color: #e5e7eb;
  transform: scale(0.98);
}

/* Footer Spacing */
.footer-spacing {
  height: 40rpx;
}
