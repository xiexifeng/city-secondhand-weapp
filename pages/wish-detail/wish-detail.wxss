/* pages/wish-detail/wish-detail.wxss */

page {
  background-color: #ffffff;
  overflow-x: hidden;
  width: 100vw;
  box-sizing: border-box;
}

/* 给所有图片和视频兜底 */
image, video, img {
  max-width: 100%;
  display: block;
}

/* 临时调试样式 - 检查溢出元素 */
/* * { outline: 1px solid red; } */

.wish-detail-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #ffffff;
  overflow-x: hidden;
  width: 100%;
  position: relative;
}

/* 内容容器 */
.detail-content {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-bottom: 20rpx;
  margin-bottom: 0;
  width: 100%;
  box-sizing: border-box;
}

/* 标题和标签 */
.title-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
}

.title-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  flex: 1;
  line-height: 1.4;
}

.action-buttons {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.share-btn,
.like-btn,
.collect-btn {
  font-size: 32rpx;
  color: #64748b;
  transition: transform 0.2s;
}

.share-btn:active,
.like-btn:active,
.collect-btn:active {
  transform: scale(1.1);
}

.share-icon-image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.9;
}

.like-btn.liked {
  color: #ef4444;
}

.collect-btn.collected {
  color: #f59e0b;
}

.tags-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.tag-category {
  background-color: #d1fae5;
  color: #10b981;
}

.tag-verified {
  background-color: #f8fafc;
  color: #475569;
}

.info-row {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #475569;
}

/* 心愿描述 */
.description-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
}

/* 预期价格/交换条件 */
.budget-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.description-text {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.budget-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #f59e0b;
  display: block;
}

/* 发布者信息 */
.seller-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.report-btn {
  padding: 6rpx 12rpx;
  background-color: #fee2e2;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #dc2626;
  font-weight: 600;
}

.seller-card {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.seller-avatar {
  width: 48rpx;
  height: 48rpx;
  background-color: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.seller-info {
  flex: 1;
}

.seller-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.seller-name .tag-verified {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
}

.seller-stats {
  font-size: 22rpx;
  color: #9ca3af;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* 安全提示 */
.safety-section {
  background-color: #fffbeb;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 2rpx solid #fbbf24;
  box-shadow: 0 1rpx 2rpx rgba(217, 119, 6, 0.08);
}

.safety-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx;
  background-color: #fef3c7;
  border-radius: 8rpx;
  border-left: 4rpx solid #f59e0b;
}

.safety-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #b45309;
}

.safety-toggle {
  font-size: 22rpx;
  color: #b45309;
}

.safety-details {
  margin-top: 12rpx;
  padding: 12rpx;
  background-color: #fef3c7;
  border-radius: 8rpx;
  border-left: 4rpx solid #f59e0b;
}

.safety-item {
  font-size: 25rpx;
  color: #b45309;
  padding: 8rpx 0;
  line-height: 1.5;
}

/* 联系方式 */
.contact-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.contact-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.contact-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

.contact-action {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 600;
}

.login-prompt {
  margin-top: 12rpx;
  padding: 16rpx;
  background-color: #f3f4f6;
  border-radius: 8rpx;
  text-align: center;
  cursor: pointer;
  transition: background-color 0.2s;
}

.login-prompt:hover {
  background-color: #e5e7eb;
}

.login-prompt-text {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 600;
}

/* 底部间距 */
.bottom-spacing {
  height: 40rpx;
}

/* 举报按钮样式 */
.seller-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.seller-actions .report-btn {
  padding: 8rpx;
  border-radius: 8rpx;
  background-color: #fee2e2;
  color: #dc2626;
  font-size: 24rpx;
  cursor: pointer;
  transition: background-color 0.2s;
}

.seller-actions .report-btn:hover {
  background-color: #fecaca;
}

/* 交易地点 */
.location-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.map-container-wrapper {
  margin-top: 12rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e5e7eb;
}

.map-container {
  width: 100%;
  height: 300rpx;
  background-color: #f3f4f6;
}

.location-info {
  margin-top: 12rpx;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.location-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.location-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.distance-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  background-color: #d1fae5;
  border-radius: 16rpx;
  cursor: pointer;
  transition: background-color 0.2s;
}

.distance-badge:hover {
  background-color: #a7f3d0;
}

.distance-text {
  font-size: 22rpx;
  color: #10b981;
  font-weight: 600;
}

.distance-icon {
  font-size: 22rpx;
  color: #10b981;
}

.location-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

