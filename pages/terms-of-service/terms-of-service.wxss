page {
  background-color: #f3f4f6;
  overflow-x: hidden;
}

.terms-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f3f4f6;
  overflow-x: hidden;
}

/* Content */
.content {
  flex: 1;
  padding: 24rpx 16rpx;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* Section */
.section {
  background-color: white;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

.section-content {
  display: block;
  font-size: 24rpx;
  color: var(--text-color-secondary);
  line-height: 1.8;
  white-space: normal;
  word-break: break-word;
  overflow-wrap: anywhere;
}

/* Footer Spacing */
.footer-spacing {
  height: 40rpx;
}
