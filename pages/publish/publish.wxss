/* pages/publish/publish.wxss */

page {
  background-color: #f9fafb;
}

.publish-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}

/* ========== 顶部导航栏 ========== */
.publish-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  z-index: 10;
  position: sticky;
  top: 0;
}

.header-left,
.header-right {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  transition: background-color 0.2s;
}

.back-btn:active {
  background-color: #f3f4f6;
}

.back-btn .back-text {
  font-size: 24rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #0ea5e9;
}

/* ========== 发布方式选择页面 ========== */
.publish-type-page {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.publish-content {
  flex: 1;
  padding: 32rpx 16rpx;
}

.publish-subtitle {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 24rpx;
}

.publish-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.publish-option:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transform: translateY(-2rpx);
}

.option-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.option-icon.sell {
  background-color: #fed7aa;
}

.option-icon.exchange {
  background-color: #a7f3d0;
}

.option-icon.wish {
  background-color: #bfdbfe;
}

.option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.option-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.option-desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.4;
}

.option-arrow {
  font-size: 28rpx;
  color: #d1d5db;
  margin-left: 8rpx;
}

/* ========== 发布表单页面 ========== */
.publish-form-page {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  flex: 1;
  overflow-y: auto;
}

.form-container {
  background-color: white;
  margin: 16rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* ========== 表单区域 ========== */
.form-section {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.form-section:last-of-type {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.required {
  color: #f97316;
  margin-left: 4rpx;
  font-weight: bold;
}

.section-hint {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 8rpx;
  line-height: 1.4;
}

/* ========== 图片上传 ========== */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.image-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #f3f4f6;
}

.image-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background-color: #dc2626;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

.image-upload {
  width: 100%;
  aspect-ratio: 1;
  border: 2rpx dashed #d1d5db;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
  transition: all 0.2s;
}

.image-upload:active {
  background-color: #f3f4f6;
  border-color: #9ca3af;
}

.upload-icon {
  display: block;
  font-size: 32rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.upload-count {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

/* ========== 表单输入 ========== */
.input-with-counter {
  position: relative;
  width: 100%;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 14rpx 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background-color: #f9fafb;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
  min-height: 56rpx;
  line-height: 1.8;
}

.input-counter {
  position: absolute;
  bottom: 10rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: #9ca3af;
  z-index: 1;
  pointer-events: none;
}

.form-textarea {
  padding-bottom: 40rpx; /* 为计数器留出空间 */
}

.form-input::placeholder,
.form-textarea::placeholder {
  color: #d1d5db;
}

.form-input:focus,
.form-textarea:focus {
  outline: none;
  border-color: #10b981;
  background-color: white;
  box-shadow: 0 0 0 3rpx rgba(16, 185, 129, 0.1);
}

.form-textarea {
  min-height: 160rpx;
  resize: none;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  padding: 14rpx 16rpx;
  display: block;
  align-items: auto;
}

/* ========== Picker ========== */
.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background-color: #f9fafb;
  font-size: 28rpx;
  color: #1f2937;
  min-height: 48rpx;
}

.picker-arrow {
  color: #d1d5db;
  font-size: 24rpx;
}

/* ========== Tags ========== */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
  background-color: #ffffff;
  transition: all 0.2s;
  cursor: pointer;
  font-weight: 500;
}

.tag-item:active {
  background-color: #f3f4f6;
  transform: scale(0.98);
}

.tag-selected {
  border-color: #10b981;
  background-color: #10b981;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.2);
}

/* ========== 位置选择 ========== */
.location-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background-color: #f9fafb;
  min-height: 80rpx;
}

.location-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-text {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.location-sub {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.location-arrow {
  font-size: 24rpx;
  color: #0ea5e9;
  margin-left: 8rpx;
}

.location-display {
  background-color: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 12rpx;
  margin-bottom: 24rpx;
}

.location-display-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.location-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.location-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.location-item-label {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.location-item-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

/* ========== 表单区域 ========== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  cursor: pointer;
}

/* ========== 折叠功能 ========== */
.collapse-arrow {
  font-size: 20rpx;
  color: #94a3b8;
  transition: transform 0.3s ease;
  display: block;
  width: 24rpx;
  text-align: center;
}

.arrow-up {
  transform: rotate(180deg);
}

.arrow-down {
  transform: rotate(0deg);
}

.collapse-content {
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 单选框 ========== */
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  cursor: pointer;
  padding: 8rpx 0;
}

.radio {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  background-color: white;
  flex-shrink: 0;
  transition: all 0.2s;
}

.radio-checked {
  border-color: #0ea5e9;
  background-color: #0ea5e9;
  box-shadow: inset 0 0 0 4rpx white;
}

.radio-item .radio-text {
  font-size: 28rpx;
  color: #1f2937;
}

/* ========== 复选框 ========== */
.checkbox-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  cursor: pointer;
  padding: 8rpx 0;
}

.checkbox {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 4rpx;
  background-color: white;
  flex-shrink: 0;
  margin-top: 2rpx;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox-checked {
  border-color: #10b981;
  background-color: #10b981;
}

.checkbox-checked::after {
  content: '✓';
  color: white;
  font-size: 16rpx;
  font-weight: bold;
}

.checkbox-item .checkbox-text {
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.4;
}

/* ========== 免责声明 ========== */
.disclaimer {
  background-color: #fef3c7;
  border-left: 4rpx solid #f59e0b;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.disclaimer-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.disclaimer-icon {
  font-size: 24rpx;
}

.disclaimer-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
}

.disclaimer-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.disclaimer-item {
  display: block;
  font-size: 24rpx;
  color: #92400e;
  line-height: 1.4;
}

/* ========== 按钮 ========== */
.form-actions {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f3f4f6;
}

.btn-publish {
  width: 100%;
  padding: 16rpx;
  background-color: #10b981;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.btn-publish:active {
  background-color: #059669;
}

.btn-disabled {
  background-color: #d1d5db;
  color: #9ca3af;
}

.btn-disabled:active {
  background-color: #d1d5db;
}

/* ========== 底部固定区域 ========== */
.fixed-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-top: 1rpx solid #e5e7eb;
  padding: 16rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.footer-checkbox {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 8rpx 0;
}

/* ========== 底部间距 ========== */
.form-bottom-spacing {
  height: 200rpx;
}
