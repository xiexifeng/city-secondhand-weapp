<!--pages/publish/publish.wxml-->
<view class="publish-container">
  <!-- 发布方式选择页面 -->
  <view wx:if="{{!publishType}}" class="publish-type-page">
    <!-- 发布方式选择 -->
    <view class="publish-content">
      <text class="publish-subtitle">选择发布方式</text>
      
      <!-- 人民币出售 -->
      <view class="publish-option" bindtap="selectPublishType" data-type="sell">
        <view class="option-icon sell">💰</view>
        <view class="option-info">
          <text class="option-title">人民币出售</text>
          <text class="option-desc">出售物品，标注价格，等待买家联系</text>
        </view>
        <text class="option-arrow">›</text>
      </view>

      <!-- 以物换物 -->
      <view class="publish-option" bindtap="selectPublishType" data-type="exchange">
        <view class="option-icon exchange">🔄</view>
        <view class="option-info">
          <text class="option-title">以物换物</text>
          <text class="option-desc">发布你的物品，说明想要的东西，寻找交换机会</text>
        </view>
        <text class="option-arrow">›</text>
      </view>

      <!-- 求换墙 -->
      <view class="publish-option" bindtap="selectPublishType" data-type="wish">
        <view class="option-icon wish">❤️</view>
        <view class="option-info">
          <text class="option-title">求换墙</text>
          <text class="option-desc">发布你想要的物品，卖家看到后会主动联系你</text>
        </view>
        <text class="option-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 发布表单页面 -->
  <view wx:else class="publish-form-page">
    <!-- 表单内容 -->
    <scroll-view class="form-scroll" scroll-y scroll-into-view="{{scrollToView}}" scroll-with-animation="true">
      <view class="form-container">
        <view class="form-top-actions">
          <view class="switch-type-btn" bindtap="backToTypeSelect">
            <text class="switch-type-icon">‹</text>
            <text class="switch-type-text">返回选择发布方式</text>
          </view>
          <text class="form-page-title">
            {{publishType === 'sell' ? '出售物品' : (publishType === 'exchange' ? '以物换物' : '发布心愿')}}
          </text>
        </view>

        <!-- 图片上传 (不显示在求换墙) -->
        <view wx:if="{{publishType !== 'wish'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">上传图片</text>
            <text class="required">*</text>
          </view>
          
          <image-upload 
            images="{{images}}" 
            maxCount="9"
            bindchange="handleImageChange"
          />

          <text class="section-hint">最多上传9张图片，建议上传清晰的物品照片</text>
        </view>

        <!-- 标题 -->
        <view class="form-section">
          <view class="section-header">
            <text class="section-title">标题</text>
            <text class="required">*</text>
          </view>
          <view class="input-with-counter">
            <input 
              type="text" 
              class="form-input"
              placeholder="{{publishType === 'wish' ? '例如：求购 iPhone 15 Pro' : '例如：iPhone 14 Pro Max'}}"
              value="{{formData.title}}"
              bindinput="updateFormData"
              data-field="title"
              maxlength="30"
            />
            <text class="input-counter">{{formData.title.length}}/30</text>
          </view>
        </view>

        <!-- 描述 -->
        <view class="form-section">
          <view class="section-header">
            <text class="section-title">描述</text>
          </view>
          <view class="input-with-counter">
            <textarea 
              class="form-textarea"
              placeholder="详细描述物品信息、成色、配件等..."
              value="{{formData.description}}"
              bindinput="updateFormData"
              data-field="description"
              maxlength="500"
            />
            <text class="input-counter">{{formData.description.length}}/500</text>
          </view>
        </view>

        <!-- 价格 (仅出售) -->
        <view wx:if="{{publishType === 'sell'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">价格</text>
            <text class="required">*</text>
          </view>
          <view class="input-with-counter">
            <input 
              type="number" 
              class="form-input"
              placeholder="请输入价格"
              value="{{formData.price}}"
              bindinput="updateFormData"
              data-field="price"
              maxlength="10"
            />
            <text class="input-counter">{{formData.price.length}}/10</text>
          </view>
        </view>

        <!-- 想要物品 (仅以物换物) -->
        <view wx:if="{{publishType === 'exchange'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">我想要的物品</text>
            <text class="required">*</text>
          </view>
          <view class="input-with-counter">
            <input 
              type="text" 
              class="form-input"
              placeholder="例如：MacBook Pro 或其他3C产品"
              value="{{formData.wantItem}}"
              bindinput="updateFormData"
              data-field="wantItem"
              maxlength="50"
            />
            <text class="input-counter">{{formData.wantItem.length}}/50</text>
          </view>
        </view>

        <!-- 预期价格或交换条件 (仅求换墙) -->
        <view wx:if="{{publishType === 'wish'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">预期价格或交换条件</text>
            <text class="required">*</text>
          </view>
          <view class="input-with-counter">
            <input 
              type="text" 
              class="form-input"
              placeholder="例如：2000元以内 或 用旧iPhone换"
              value="{{formData.budget}}"
              bindinput="updateFormData"
              data-field="budget"
              maxlength="100"
            />
            <text class="input-counter">{{formData.budget.length}}/100</text>
          </view>
        </view>

        <!-- Tags (不显示在求换墙) -->
        <view wx:if="{{publishType !== 'wish'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">标签</text>
          </view>
          <view class="tags-container">
            <view 
              wx:for="{{tags}}" 
              wx:key="index"
              class="tag-item {{item.selected ? 'tag-selected' : ''}}"
              bindtap="toggleTag"
              data-tag="{{item.name}}"
            >
              {{item.name}}
            </view>
          </view>
          <text class="section-hint">最多选择3个标签，帮助物品更快被发现</text>
        </view>

        <!-- 分类 -->
        <view class="form-section">
          <view class="section-header">
            <text class="section-title">分类</text>
          </view>
          <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categories}}">
            <view class="picker-item">
              <text>{{formData.category}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <!-- 物品成色 (不显示在求换墙) -->
        <view wx:if="{{publishType !== 'wish'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">物品成色</text>
          </view>
          <picker bindchange="onConditionChange" value="{{conditionIndex}}" range="{{conditions}}">
            <view class="picker-item">
              <text>{{formData.condition}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
          <text class="section-hint">帮助买家了解物品的使用状况</text>
        </view>

        <!-- 位置选择 -->
        <view class="form-section">
          <view class="section-header">
            <text class="section-title">📍 预期交易地点</text>
          </view>
          <view class="location-picker" bindtap="openLocationPicker">
            <view class="location-main">
              <text class="location-text">{{formData.location}}</text>
              <text class="location-sub">{{locationDetails.province}} / {{locationDetails.city}} / {{locationDetails.district}}</text>
            </view>
            <text class="location-arrow">›</text>
          </view>
          <text class="section-hint">设置交易地点可以提高交易成功率</text>
        </view>

        <!-- 联系方式设置 (可折叠) -->
        <view class="form-section">
          <view class="section-header" bindtap="toggleContactSettings">
            <text class="section-title">联系方式设置</text>
            <text class="collapse-arrow {{contactSettingsExpanded ? 'arrow-up' : 'arrow-down'}}">▼</text>
          </view>
          
          <view wx:if="{{contactSettingsExpanded}}" class="collapse-content">
            <view class="radio-group">
              <label class="radio-item" bindtap="updateContactVisibility" data-value="both">
                <view class="radio {{formData.contactVisibility === 'both' ? 'radio-checked' : ''}}"></view>
                <text class="radio-text">显示微信和电话</text>
              </label>
              <label class="radio-item" bindtap="updateContactVisibility" data-value="wechat">
                <view class="radio {{formData.contactVisibility === 'wechat' ? 'radio-checked' : ''}}"></view>
                <text class="radio-text">仅显示微信</text>
              </label>
              <label class="radio-item" bindtap="updateContactVisibility" data-value="phone">
                <view class="radio {{formData.contactVisibility === 'phone' ? 'radio-checked' : ''}}"></view>
                <text class="radio-text">仅显示电话</text>
              </label>
            </view>

            <text class="section-hint">选择买家可以看到的联系方式，保护您的隐私</text>
          </view>
        </view>

        <!-- 微信 -->
        <view wx:if="{{formData.contactVisibility === 'both' || formData.contactVisibility === 'wechat'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">微信</text>
            <text class="required">*</text>
          </view>
          <view class="input-with-counter">
            <input 
              type="text" 
              class="form-input"
              placeholder="请输入微信号"
              value="{{formData.wechat}}"
              bindinput="updateFormData"
              data-field="wechat"
              maxlength="20"
            />
            <text class="input-counter">{{formData.wechat.length}}/20</text>
          </view>
        </view>

        <!-- 电话 -->
        <view wx:if="{{formData.contactVisibility === 'both' || formData.contactVisibility === 'phone'}}" class="form-section">
          <view class="section-header">
            <text class="section-title">电话</text>
            <text class="required">*</text>
          </view>
          <view class="input-with-counter">
            <input 
              type="number" 
              class="form-input"
              placeholder="请输入手机号"
              value="{{formData.phone}}"
              bindinput="updateFormData"
              data-field="phone"
              maxlength="11"
            />
            <text class="input-counter">{{formData.phone.length}}/11</text>
          </view>
        </view>

        <!-- 联系方式提示 -->
        <view class="form-section">
          <text class="section-hint">完整的联系方式可以提高交易成功率</text>
        </view>


        <!-- 底部固定区域 -->
        <view class="fixed-footer">
          <!-- 同意免责声明 -->
          <view class="footer-checkbox" bindtap="toggleAgreed">
            <view class="checkbox {{agreed ? 'checkbox-checked' : ''}}"></view>
            <text class="checkbox-text">我已阅读并同意免责声明</text>
          </view>
          
          <!-- 发布按钮 -->
          <button class="btn-publish {{(!agreed || !canPublish || isSubmitting) ? 'btn-disabled' : ''}}" bindtap="handlePublish" disabled="{{!agreed || !canPublish || isSubmitting}}">
            {{isSubmitting ? '发布中...' : (readCountdown > 0 ? '阅读中 ' + readCountdown + 's' : '发布')}}
          </button>
        </view>

        <!-- 免责声明 -->
        <view id="disclaimer-section" class="disclaimer">
          <view class="disclaimer-header">
            <text class="disclaimer-icon">⚠️</text>
            <text class="disclaimer-title">免责声明</text>
          </view>
          <view class="disclaimer-content">
            <text class="disclaimer-item">• 发布的物品信息必须真实有效</text>
            <text class="disclaimer-item">• 禁止发布违法违规、虚假、骗诈内容</text>
            <text class="disclaimer-item">• 禁止发布违禁品、侵权商品</text>
            <text class="disclaimer-item">• 平台不介入交易纠纷，请自行协商</text>
          </view>
        </view>

        <!-- 底部间距 -->
        <view class="form-bottom-spacing"></view>
      </view>
    </scroll-view>
  </view>

</view>
