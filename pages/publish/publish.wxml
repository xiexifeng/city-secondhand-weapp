<!--pages/publish/publish.wxml-->
<view class="publish-container">
  <view class="publish-header">
    <text class="publish-title">发布物品</text>
  </view>
  
  <view class="publish-form">
    <!-- 图片上传 -->
    <view class="form-section">
      <text class="section-title">物品图片</text>
      <view class="image-uploader" bindtap="handleUploadImage">
        <view class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">上传图片</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="form-section">
      <text class="section-title">基本信息</text>
      <view class="form-group">
        <text class="form-label">物品名称</text>
        <input type="text" placeholder="请输入物品名称" class="form-input" />
      </view>
    </view>

    <!-- 交易方式 -->
    <view class="form-section">
      <text class="section-title">交易方式</text>
      <view class="trade-type-group">
        <view class="trade-type-item active">人民币</view>
        <view class="trade-type-item">以物换物</view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="form-actions">
      <button class="btn-submit">发布</button>
      <button class="btn-cancel">取消</button>
    </view>
  </view>
</view>
