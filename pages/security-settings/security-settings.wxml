<!--pages/security-settings/security-settings.wxml-->
<view class="security-settings-container">
  <!-- Header -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-arrow">‹</text>
      <text class="header-title">密码和安全</text>
    </view>
  </view>

  <!-- Security Items -->
  <view class="security-list">
    <!-- Phone Binding -->
    <view class="security-item">
      <view class="item-header">
        <view class="item-icon phone-icon">📱</view>
        <view class="item-content">
          <text class="item-title">手机绑定</text>
          <text class="item-status {{security.phoneBound ? 'bound' : 'unbound'}}">{{security.phoneBound ? '已绑定 ' + security.phone : '未绑定'}}</text>
        </view>
      </view>
      <view class="item-action" bindtap="handlePhoneBinding">
        <text class="action-text">{{security.phoneBound ? '更换' : '绑定'}}</text>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- Email Binding -->
    <view class="security-item">
      <view class="item-header">
        <view class="item-icon email-icon">📧</view>
        <view class="item-content">
          <text class="item-title">邮箱绑定</text>
          <text class="item-status {{security.emailBound ? 'bound' : 'unbound'}}">{{security.emailBound ? '已绑定 ' + security.email : '未绑定'}}</text>
        </view>
      </view>
      <view class="item-action" bindtap="handleEmailBinding">
        <text class="action-text">{{security.emailBound ? '更换' : '绑定'}}</text>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- Password -->
    <view class="security-item">
      <view class="item-header">
        <view class="item-icon password-icon">🔐</view>
        <view class="item-content">
          <text class="item-title">修改密码</text>
          <text class="item-description">定期修改密码可以提高账户安全性</text>
        </view>
      </view>
      <view class="item-action" bindtap="handleChangePassword">
        <text class="action-text">修改</text>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- Two-Factor Auth -->
    <view class="security-item">
      <view class="item-header">
        <view class="item-icon auth-icon">✓</view>
        <view class="item-content">
          <text class="item-title">两步验证</text>
          <text class="item-status {{security.twoFactorEnabled ? 'bound' : 'unbound'}}">{{security.twoFactorEnabled ? '已启用' : '未启用'}}</text>
        </view>
      </view>
      <view class="item-action" bindtap="handleTwoFactorAuth">
        <text class="action-text">{{security.twoFactorEnabled ? '关闭' : '启用'}}</text>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Tips -->
  <view class="tips-section">
    <text class="tips-title">🔒 安全建议</text>
    <text class="tips-item">• 使用强密码，包含大小写字母、数字和符号</text>
    <text class="tips-item">• 定期修改密码，不要使用相同的密码</text>
    <text class="tips-item">• 启用两步验证以增强账户安全</text>
    <text class="tips-item">• 不要在公共电脑上登录账户</text>
  </view>

  <!-- Logout -->
  <view class="btn-group">
    <view class="btn btn-logout" bindtap="handleLogout">退出登录</view>
  </view>
</view>
