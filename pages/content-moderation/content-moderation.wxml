<!--pages/content-moderation/content-moderation.wxml-->
<view class="moderation-container">
  <!-- Stats Cards -->
  <view class="stats-container">
    <view class="stat-card pending">
      <text class="stat-number">{{stats.pending}}</text>
      <text class="stat-label">待审核</text>
    </view>
    <view class="stat-card approved">
      <text class="stat-number">{{stats.approved}}</text>
      <text class="stat-label">已通过</text>
    </view>
    <view class="stat-card rejected">
      <text class="stat-number">{{stats.rejected}}</text>
      <text class="stat-label">已拒绝</text>
    </view>
    <view class="stat-card points">
      <text class="stat-number">{{stats.totalReviewed * 5}}</text>
      <text class="stat-label">已获积分</text>
    </view>
  </view>

  <!-- Filter Buttons -->
  <view class="filter-container">
    <view 
      class="filter-btn {{filterStatus === 'pending' ? 'active' : ''}}"
      bindtap="setFilterStatus"
      data-status="pending"
    >
      待审核
    </view>
    <view 
      class="filter-btn {{filterStatus === 'all' ? 'active' : ''}}"
      bindtap="setFilterStatus"
      data-status="all"
    >
      全部
    </view>
  </view>

  <!-- Content Scroll -->
  <scroll-view scroll-y class="content-scroll">
    <!-- Empty State -->
    <view wx:if="{{filteredItems.length === 0}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无审核内容</text>
      <text class="empty-text">稍后再来看看吧</text>
    </view>

    <!-- Items List -->
    <view wx:else class="items-list">
      <view 
        wx:for="{{filteredItems}}" 
        wx:key="id"
        class="moderation-item"
        bindtap="navigateToDetail"
        data-id="{{item.id}}"
      >
        <image class="item-image" src="{{item.image}}" mode="aspectFill" />
        
        <view class="item-content">
          <view class="item-badges">
            <view class="badge type-badge">{{item.type === 'item' ? '物品' : '心愿'}}</view>
            <view wx:if="{{item.reason}}" class="badge reason-badge">{{item.reason}}</view>
          </view>
          
          <text class="item-title">{{item.title}}</text>
          <text class="item-desc">{{item.description}}</text>
          
          <view class="item-publisher">
            <view class="publisher-avatar">{{item.publisher.avatar}}</view>
            <view class="publisher-info">
              <text class="publisher-name">{{item.publisher.name}}</text>
              <text class="publisher-time">{{item.submittedAt}}</text>
            </view>
          </view>
        </view>

        <view class="item-status">
          <view class="status-dot {{item.status}}"></view>
        </view>
      </view>
    </view>

    <!-- Footer Spacing -->
    <view class="footer-spacing"></view>
  </scroll-view>
</view>
