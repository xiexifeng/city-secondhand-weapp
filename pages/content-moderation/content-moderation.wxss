page {
  background-color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.moderation-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8fafc;
}

/* Stats Container */
.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 20rpx 16rpx;
  background-color: white;
  border-bottom: 1rpx solid #e2e8f0;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  text-align: center;
  transition: transform 0.2s ease;
}

.stat-card:active {
  transform: scale(0.98);
}

.stat-card.pending {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
}

.stat-card.approved {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
}

.stat-card.rejected {
  background: linear-gradient(135deg, #fed7aa 0%, #fdba74 100%);
}

.stat-card.points {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.stat-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
  display: block;
  font-weight: 500;
  line-height: 1.3;
}

/* Filter Container */
.filter-container {
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
  background-color: white;
  border-bottom: 1rpx solid #e2e8f0;
}

.filter-btn {
  flex: 1;
  padding: 14rpx 20rpx;
  border-radius: 28rpx;
  background-color: #f1f5f9;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  text-align: center;
}

.filter-btn.active {
  background-color: #3b82f6;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.filter-btn:active {
  transform: scale(0.98);
}

/* Content Scroll */
.content-scroll {
  flex: 1;
  overflow-y: auto;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 16rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  color: #10b981;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.empty-text {
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.5;
  max-width: 400rpx;
}

/* Items List */
.items-list {
  padding: 16rpx;
}

.moderation-item {
  display: flex;
  gap: 20rpx;
  background-color: white;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
  align-items: flex-start;
  position: relative;
}

.moderation-item:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transform: scale(0.99);
}

.item-image-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background-color: #f1f5f9;
  overflow: hidden;
}

.item-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100rpx;
  padding-right: 40rpx;
}

.item-badges {
  display: flex;
  gap: 8rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
  align-items: center;
}

.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 16rpx;
  font-weight: 600;
  line-height: 1.2;
}

.type-badge {
  background-color: #dbeafe;
  color: #1e40af;
}

.reason-badge {
  background-color: #fed7aa;
  color: #9a3412;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.item-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 16rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.5;
  max-width: 100%;
}

.item-id-container {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.item-id-label {
  font-size: 20rpx;
  color: #64748b;
  font-weight: 500;
  flex-shrink: 0;
}

.item-id {
  font-size: 20rpx;
  color: #1e293b;
  font-weight: 600;
  font-family: monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.item-publisher {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  width: 100%;
}

.publisher-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ec4899 0%, #a855f7 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.publisher-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.publisher-name {
  font-size: 20rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  line-height: 1.3;
}

.publisher-time {
  font-size: 16rpx;
  color: #94a3b8;
  display: block;
  line-height: 1.3;
}

.status-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.status-dot.pending {
  background-color: #f59e0b;
  animation: pulse 2s infinite;
  box-shadow: 0 0 0 4rpx rgba(245, 158, 11, 0.2);
}

.status-dot.approved {
  background-color: #10b981;
  box-shadow: 0 0 0 4rpx rgba(16, 185, 129, 0.2);
}

.status-dot.rejected {
  background-color: #ef4444;
  box-shadow: 0 0 0 4rpx rgba(239, 68, 68, 0.2);
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.1);
  }
}

/* Footer Spacing */
.footer-spacing {
  height: 60rpx;
}
