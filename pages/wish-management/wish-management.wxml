<!--pages/wish-management/wish-management.wxml-->
<view class="wish-management-container">
  <!-- Header -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-arrow">‹</text>
      <view class="header-text">
        <text class="header-title">我的求换</text>
        <text class="header-subtitle">共 {{wishes.length}} 个心愿</text>
      </view>
    </view>
    <view class="add-btn" bindtap="navigateToPublish">
      <text class="add-icon">+</text>
      <text class="add-text">新增</text>
    </view>
  </view>

  <!-- Stats Cards -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-value">{{activeCount}}</text>
      <text class="stat-label">活跃心愿</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{totalInterests}}</text>
      <text class="stat-label">总感兴趣</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{totalViews}}</text>
      <text class="stat-label">总浏览</text>
    </view>
  </view>

  <!-- Wishes List -->
  <view class="wishes-list">
    <!-- Active Wishes Section -->
    <view wx:if="{{activeWishes.length > 0}}" class="section">
      <text class="section-title">活跃心愿</text>
      <view class="wishes-section">
        <view wx:for="{{activeWishes}}" wx:key="id" class="wish-card">
          <!-- View Mode -->
          <view wx:if="{{editingId !== item.id}}" class="wish-view">
            <view class="wish-header">
              <text class="wish-icon">❤️</text>
              <view class="wish-content">
                <text class="wish-title">{{item.title}}</text>
                <text class="wish-description">{{item.description}}</text>
              </view>
              <view class="wish-menu" bindtap="toggleMenu" data-id="{{item.id}}">
                <text class="menu-icon">⋯</text>
              </view>
            </view>

            <view class="wish-tags">
              <view class="tag tag-method">{{item.expectedMethod}}</view>
              <view wx:if="{{item.priceRange}}" class="tag tag-price">{{item.priceRange}}</view>
              <view wx:if="{{item.reviewStatus}}" class="tag {{item.reviewStatusClass}}">
                {{item.reviewStatusLabel}}
              </view>
            </view>

            <view wx:if="{{item.reviewStatus === '审核不通过' && item.rejectionReason}}" class="rejection-reason">
              <text class="reason-label">拒绝原因：{{item.rejectionReason}}</text>
            </view>

            <view class="wish-footer">
              <text class="wish-date">{{item.createdAt}}</text>
              <view class="wish-stats">
                <text class="stat-item">👁 {{item.views}}</text>
                <text class="stat-item">❤️ {{item.interests}}</text>
              </view>
            </view>

            <!-- Menu -->
            <view wx:if="{{activeMenu === item.id && (item.reviewStatus === '审核不通过' || item.reviewStatus === '已通过')}}" class="menu-popup-wrapper">
              <view class="menu-popup" catchtap="noop">
                <!-- 只有审核不通过的才能编辑和删除 -->
                <view wx:if="{{item.reviewStatus === '审核不通过'}}" class="menu-item" bindtap="handleEdit" data-id="{{item.id}}">
                  <text class="menu-icon">✏️</text>
                  <text class="menu-text">编辑</text>
                </view>
                <!-- 审核通过的能改变状态 -->
                <view wx:if="{{item.reviewStatus === '已通过'}}" class="menu-item" bindtap="handleToggleStatus" data-id="{{item.id}}">
                  <text class="menu-icon">🔄</text>
                  <text class="menu-text">下架</text>
                </view>
                <!-- 只有审核不通过的才能删除 -->
                <view wx:if="{{item.reviewStatus === '审核不通过'}}" class="menu-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                  <text class="menu-icon">🗑️</text>
                  <text class="menu-text">删除</text>
                </view>
              </view>
            </view>
          </view>


        </view>
      </view>
    </view>

    <!-- Archived Wishes Section -->
    <view wx:if="{{archivedWishes.length > 0}}" class="section">
      <text class="section-title">已下架心愿</text>
      <view class="wishes-section archived">
        <view wx:for="{{archivedWishes}}" wx:key="id" class="wish-card archived-card">
          <!-- View Mode -->
          <view class="wish-view">
            <view class="wish-header">
              <text class="wish-icon">❤️</text>
              <view class="wish-content">
                <text class="wish-title">{{item.title}}</text>
                <text class="wish-description">{{item.description}}</text>
              </view>
              <view class="wish-menu" bindtap="toggleMenu" data-id="{{item.id}}">
                <text class="menu-icon">⋯</text>
              </view>
            </view>

            <view class="wish-tags">
              <view class="tag tag-method">{{item.expectedMethod}}</view>
              <view wx:if="{{item.priceRange}}" class="tag tag-price">{{item.priceRange}}</view>
              <view wx:if="{{item.reviewStatus}}" class="tag {{item.reviewStatusClass}}">
                {{item.reviewStatusLabel}}
              </view>
            </view>

            <view wx:if="{{item.reviewStatus === '审核不通过' && item.rejectionReason}}" class="rejection-reason">
              <text class="reason-label">拒绝原因：{{item.rejectionReason}}</text>
            </view>

            <view class="wish-footer">
              <text class="wish-date">{{item.createdAt}}</text>
              <view class="wish-stats">
                <text class="stat-item">👁 {{item.views}}</text>
                <text class="stat-item">❤️ {{item.interests}}</text>
              </view>
            </view>

            <!-- Menu -->
            <view wx:if="{{activeMenu === item.id && (item.reviewStatus === '审核不通过' || item.reviewStatus === '已通过')}}" class="menu-popup-wrapper">
              <view class="menu-popup" catchtap="noop">
                <!-- 只有审核不通过的才能编辑和删除 -->
                <view wx:if="{{item.reviewStatus === '审核不通过'}}" class="menu-item" bindtap="handleEdit" data-id="{{item.id}}">
                  <text class="menu-icon">✏️</text>
                  <text class="menu-text">编辑</text>
                </view>
                <!-- 审核通过的能改变状态 -->
                <view wx:if="{{item.reviewStatus === '已通过'}}" class="menu-item" bindtap="handleToggleStatus" data-id="{{item.id}}">
                  <text class="menu-icon">🔄</text>
                  <text class="menu-text">上架</text>
                </view>
                <!-- 只有审核不通过的才能删除 -->
                <view wx:if="{{item.reviewStatus === '审核不通过'}}" class="menu-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                  <text class="menu-icon">🗑️</text>
                  <text class="menu-text">删除</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Empty State -->
    <view wx:if="{{wishes.length === 0}}" class="empty-state">
      <text class="empty-icon">💭</text>
      <text class="empty-title">还没有任何心愿</text>
      <view class="empty-btn" bindtap="navigateToPublish">去发布心愿</view>
    </view>
  </view>

  <!-- Menu Overlay -->
  <view wx:if="{{activeMenu !== null}}" class="menu-overlay" bindtap="closeMenu"></view>
</view>
