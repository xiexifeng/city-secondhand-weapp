<!--pages/wish-management/wish-management.wxml-->
<view class="wish-management-container">


  <!-- Stats Cards -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-value">{{activeCount}}</text>
      <text class="stat-label">活跃心愿</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{totalInterests}}</text>
      <text class="stat-label">总感兴趣</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{totalViews}}</text>
      <text class="stat-label">总浏览</text>
    </view>
  </view>

  <!-- Wishes List -->
  <view class="wishes-list">
    <!-- Active Wishes Section -->
    <view wx:if="{{activeWishes.length > 0}}" class="section">
      <text class="section-title">活跃心愿</text>
      <view class="wishes-section">
        <view wx:for="{{activeWishes}}" wx:key="id" class="wish-card">
          <view class="wish-view">
            <view class="wish-header">
              <text class="wish-icon">❤️</text>
              <view class="wish-content">
                <text class="wish-title">{{item.title}}</text>
                <text class="wish-description">{{item.description}}</text>
              </view>
            </view>

            <view class="wish-tags">
              <view wx:if="{{item.budget}}" class="tag tag-budget">预算: {{item.budget}}</view>
              <view class="tag {{item.statusClass}}">{{item.statusLabel}}</view>
            </view>

            <view wx:if="{{item.status === 'inactive' && item.rejectionReason}}" class="rejection-reason">
              <text class="reason-label">拒绝原因：{{item.rejectionReason}}</text>
            </view>

            <view class="wish-footer">
              <text class="wish-date">{{item.createdAt}}</text>
              <view class="wish-stats">
                <text class="stat-item">👁️ {{item.views}}</text>
                <text class="stat-item">❤️ {{item.interests}}</text>
                <text class="stat-item">⭐ {{item.favorites}}</text>
              </view>
            </view>

            <!-- Actions -->
            <view class="wish-actions">
              <view wx:if="{{item.status === 'inactive'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                  <text class="action-text">删除</text>
                </view>
                <view class="action-item" bindtap="handleEdit" data-id="{{item.id}}">
                  <text class="action-text">编辑</text>
                </view>
              </view>
              <view wx:if="{{item.status === 'auditing'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                  <text class="action-text">删除</text>
                </view>
              </view>
              <view wx:if="{{item.status === 'active'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                <view class="action-item achieve" bindtap="handleAchieve" data-id="{{item.id}}">
                  <text class="action-text">心愿达成</text>
                </view>
                <view class="action-item withdraw" bindtap="handleWithdraw" data-id="{{item.id}}">
                  <text class="action-text">撤回心愿</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Archived Wishes Section -->
    <view wx:if="{{archivedWishes.length > 0}}" class="section">
      <text class="section-title">已结束心愿</text>
      <view class="wishes-section archived">
        <view wx:for="{{archivedWishes}}" wx:key="id" class="wish-card archived-card">
          <view class="wish-view">
            <view class="wish-header">
              <text class="wish-icon">❤️</text>
              <view class="wish-content">
                <text class="wish-title">{{item.title}}</text>
                <text class="wish-description">{{item.description}}</text>
              </view>
            </view>

            <view class="wish-tags">
              <view wx:if="{{item.budget}}" class="tag tag-budget">预算: {{item.budget}}</view>
              <view class="tag {{item.statusClass}}">{{item.statusLabel}}</view>
            </view>

            <view class="wish-footer">
              <text class="wish-date">{{item.createdAt}}</text>
              <view class="wish-stats">
                <text class="stat-item">👁️ {{item.views}}</text>
                <text class="stat-item">❤️ {{item.interests}}</text>
                <text class="stat-item">⭐ {{item.favorites}}</text>
              </view>
            </view>

            <!-- Actions -->
            <view class="wish-actions">
              <view wx:if="{{item.status === 'cancelled'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                  <text class="action-text">删除</text>
                </view>
              </view>
              <view wx:if="{{item.status === 'inactive'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                  <text class="action-text">删除</text>
                </view>
                <view class="action-item" bindtap="handleEdit" data-id="{{item.id}}">
                  <text class="action-text">编辑</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Empty State -->
    <view wx:if="{{wishes.length === 0}}" class="empty-state">
      <text class="empty-icon">💭</text>
      <text class="empty-title">还没有任何心愿</text>
      <view class="empty-btn" bindtap="navigateToPublish">去发布心愿</view>
    </view>
  </view>


</view>
