/* pages/wish-management/wish-management.wxss */

page {
  background-color: #f3f4f6;
}

.wish-management-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
  flex: 1;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-text {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.header-subtitle {
  font-size: 16rpx;
  color: #9ca3af;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 12rpx;
  background-color: #10b981;
  color: white;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 600;
  cursor: pointer;
  flex-shrink: 0;
}

.add-icon {
  font-size: 20rpx;
}

.add-text {
  display: block;
}

/* Stats Section */
.stats-section {
  padding: 12rpx 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.stat-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #0ea5e9;
}

.stat-label {
  font-size: 18rpx;
  color: #9ca3af;
}

/* Wishes List */
.wishes-list {
  padding: 12rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Section Title */
.section-title {
  display: block;
  font-size: 18rpx;
  font-weight: 600;
  color: #9ca3af;
  padding: 0 8rpx;
  margin-bottom: 8rpx;
}

/* Wishes Section */
.wishes-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.wishes-section.archived {
  opacity: 0.6;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 16rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.empty-btn {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #0ea5e9;
  color: white;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 600;
}

/* Wish Card */
.wish-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.wish-card.archived-card {
  opacity: 0.7;
}

/* Wish View */
.wish-view {
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.wish-header {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.wish-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.wish-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.wish-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
}

.wish-description {
  display: block;
  font-size: 18rpx;
  color: #9ca3af;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.wish-menu {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  background-color: #f3f4f6;
  cursor: pointer;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 18rpx;
  color: #9ca3af;
}

/* Wish Tags */
.wish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 600;
}

.tag-method {
  background-color: #dbeafe;
  color: #0c4a6e;
}

.tag-price {
  background-color: #fed7aa;
  color: #92400e;
}

.tag-status {
  background-color: #dcfce7;
  color: #166534;
}

.tag.review-pending {
  background-color: #fef3c7;
  color: #92400e;
}

.tag.review-approved {
  background-color: #dcfce7;
  color: #166534;
}

.tag.review-rejected {
  background-color: #fee2e2;
  color: #991b1b;
}

/* Rejection Reason */
.rejection-reason {
  padding: 8rpx;
  background-color: #fee2e2;
  border-radius: 4rpx;
}

.reason-label {
  display: block;
  font-size: 18rpx;
  color: #991b1b;
  font-weight: 600;
}

/* Wish Footer */
.wish-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 18rpx;
  color: #9ca3af;
  padding-top: 8rpx;
  border-top: 1rpx solid #e5e7eb;
}

.wish-date {
  display: block;
}

.wish-stats {
  display: flex;
  gap: 12rpx;
}

.stat-item {
  display: inline-block;
}

/* Menu */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.menu-popup {
  position: absolute;
  top: 40rpx;
  right: 16rpx;
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  z-index: 101;
  min-width: 120rpx;
}

.menu-item {
  padding: 12rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 18rpx;
  color: #1f2937;
  cursor: pointer;
  transition: background-color 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9fafb;
}

.menu-item.delete {
  color: #dc2626;
}

.menu-item.delete:active {
  background-color: #fee2e2;
}

.menu-text {
  display: block;
}

/* Wish Edit */
.wish-edit {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.form-label {
  display: block;
  font-size: 18rpx;
  font-weight: 600;
  color: #1f2937;
}

.form-input {
  padding: 8rpx 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 18rpx;
  color: #1f2937;
  min-height: 40rpx;
}

.form-input.picker {
  display: flex;
  align-items: center;
}

.form-textarea {
  padding: 8rpx 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 18rpx;
  color: #1f2937;
  min-height: 100rpx;
}

/* Edit Actions */
.edit-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.btn {
  flex: 1;
  padding: 12rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}

.btn-save {
  background-color: #10b981;
  color: white;
}

.btn-save:active {
  background-color: #059669;
}

.btn-cancel {
  background-color: #e5e7eb;
  color: #1f2937;
}

.btn-cancel:active {
  background-color: #d1d5db;
}
