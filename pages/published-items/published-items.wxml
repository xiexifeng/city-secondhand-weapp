<!--pages/published-items/published-items.wxml-->
<view class="published-items-container">

  <!-- Stats Cards -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-value">{{items.length}}</text>
      <text class="stat-label">总发布</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{statusCounts.onSale}}</text>
      <text class="stat-label">在售</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{statusCounts.trading}}</text>
      <text class="stat-label">成交中</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{statusCounts.completed}}</text>
      <text class="stat-label">已成交</text>
    </view>
  </view>

  <!-- Items List -->
  <view class="items-list">
    <view wx:if="{{items.length === 0}}" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-title">还没有发布任何物品</text>
      <view class="empty-btn" bindtap="navigateToPublish">去发布物品</view>
    </view>

    <view wx:for="{{items}}" wx:key="id" class="item-card">
      <!-- View Mode -->
      <view class="item-view">
        <view class="item-header">
          <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="item-info">
            <view class="item-title-row">
              <text class="item-title">{{item.title}}</text>
            </view>
            <text class="item-date">{{item.publishDate}}</text>

            <view class="item-badges">
              <text class="item-price">¥{{item.price}}</text>
              <view class="status-badge {{item.statusClass}}">{{item.status}}</view>
              <view wx:if="{{item.reviewStatus}}" class="review-status {{item.reviewStatusClass}}">
                {{item.reviewStatusLabel}}
              </view>
            </view>

            <view wx:if="{{item.reviewStatus === '审核不通过' && item.rejectionReason}}" class="rejection-reason">
              <text class="reason-label">拒绝原因：{{item.rejectionReason}}</text>
            </view>

            <view class="item-stats">
              <text class="stat-item">👁️ {{item.views}}</text>
              <text class="stat-item">❤️ {{item.likes}}</text>
              <text class="stat-item">⭐ {{item.favorites}}</text>
            </view>

            <!-- Actions -->
            <view class="item-actions">
              <!-- 审核通过的物品操作 -->
              <view wx:if="{{item.reviewStatus === '已通过'}}">
                <!-- 出售中 -->
                <view wx:if="{{item.status === '在售'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                  <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                    <text class="action-text">删除</text>
                  </view>
                  <view class="action-item offline" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="offline">
                    <text class="action-text">取消发布</text>
                  </view>
                  <view class="action-item completed" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="completed">
                    <text class="action-text">已成交</text>
                  </view>
                </view>
                <!-- 已下架 -->
                <view wx:if="{{item.status === '已下架'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                  <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                    <text class="action-text">删除</text>
                  </view>
                  <view class="action-item on-sale" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="onSale">
                    <text class="action-text">发起出售</text>
                  </view>
                </view>
                <!-- 已成交 -->
                <view wx:if="{{item.status === '已成交'}}">
                  <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                    <text class="action-text">删除</text>
                  </view>
                </view>
              </view>
              <!-- 审核不通过的物品操作 -->
              <view wx:if="{{item.reviewStatus === '审核不通过'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                  <text class="action-text">删除</text>
                </view>
                <view class="action-item" bindtap="handleEdit" data-id="{{item.id}}">
                  <text class="action-text">编辑</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>


    </view>
  </view>



  <!-- Status Change Modal -->
  <view wx:if="{{showStatusModal && selectedItem}}" class="status-modal-overlay" bindtap="closeStatusModal">
    <view class="status-modal" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">改变"{{selectedItem.title}}"的状态</text>
      </view>
      <view class="modal-content">
        <view class="status-options">
          <view wx:for="{{statusOptions}}" wx:key="status" class="status-option {{item.class}}" bindtap="handleStatusChange" data-status="{{item.status}}">
            <text class="option-label">{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <view class="btn btn-close" bindtap="closeStatusModal">关闭</view>
      </view>
    </view>
  </view>
</view>
