<!--pages/published-items/published-items.wxml-->
<view class="published-items-container">

  <!-- Safety Tip -->
  <view class="safety-tip">
    <view class="tip-icon">🔒</view>
    <text class="tip-text">安全交易提示：请选择公共场所进行物品交接，保护个人财产安全</text>
  </view>

  <!-- Stats Cards -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-value">{{items.length}}</text>
      <text class="stat-label">总发布</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{statusCounts.transferring}}</text>
      <text class="stat-label">发布中</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{statusCounts.transfer_accepted}}</text>
      <text class="stat-label">已达成</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{statusCounts.transferred}}</text>
      <text class="stat-label">已转让</text>
    </view>
  </view>

  <!-- Items List -->
  <view class="items-list">
    <view wx:if="{{items.length === 0}}" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-title">还没有发布任何物品</text>
      <view class="empty-btn" bindtap="navigateToPublish">去发布物品</view>
    </view>

    <view wx:for="{{items}}" wx:key="id" class="item-card">
      <!-- View Mode -->
      <view class="item-view">
        <view class="item-header">
          <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="item-info">
            <view class="item-title-row">
              <text class="item-title">{{item.title}}</text>
            </view>

            <view class="item-badges">
              <text wx:if="{{item.transactionType === '以物换物' || !item.price}}" class="item-price exchange">以物换物</text>
              <text wx:else class="item-price">¥{{item.price}}</text>
              <view wx:if="{{item.transferStatus}}" class="status-badge {{item.transferStatusClass}}">{{item.transferStatusLabel}}</view>
              <view wx:if="{{item.status}}" class="review-status {{item.reviewStatusClass}}">
                {{item.reviewStatusLabel}}
              </view>
            </view>

            <view wx:if="{{item.reviewStatus === '审核不通过' && item.rejectionReason}}" class="rejection-reason">
              <text class="reason-label">拒绝原因：{{item.rejectionReason}}</text>
            </view>

            <view class="item-stats">
              <text class="stat-item">👁️ {{item.views}}</text>
              <text class="stat-item">❤️ {{item.likes}}</text>
              <text class="stat-item">⭐ {{item.favorites}}</text>
            </view>

            <!-- Actions -->
            <view class="item-actions">
              <view class="actions-left">
                <text class="item-date">{{item.publishDate}}</text>
              </view>
              <view class="actions-right">
                <!-- 审核不通过的物品操作 -->
                <view wx:if="{{item.status === 'inactive'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                  <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                    <text class="action-text">删除</text>
                  </view>
                  <view class="action-item" bindtap="handleEdit" data-id="{{item.id}}">
                    <text class="action-text">编辑</text>
                  </view>
                </view>
                
                <!-- 审核通过的物品操作 -->
                <view wx:if="{{item.status === 'active'}}">
                  <!-- 待发布 -->
                  <view wx:if="{{item.transferStatus === 'own'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                    <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                      <text class="action-text">删除</text>
                    </view>
                    <view class="action-item on-sale" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transferring">
                      <text class="action-text">发起转让</text>
                    </view>
                  </view>
                  
                  <!-- 发布中 -->
                  <view wx:if="{{item.transferStatus === 'transferring'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                    <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                      <text class="action-text">删除</text>
                    </view>
                    <view class="action-item offline" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transfer_cancelled">
                      <text class="action-text">取消发布</text>
                    </view>
                    <view class="action-item accepted" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transfer_accepted">
                      <text class="action-text">已接受</text>
                    </view>
                    <view class="action-item completed" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transferred">
                      <text class="action-text">已转让</text>
                    </view>
                  </view>
                  
                  <!-- 已接受 -->
                  <view wx:if="{{item.transferStatus === 'transfer_accepted'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                    <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                      <text class="action-text">删除</text>
                    </view>
                    <view class="action-item offline" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transfer_cancelled">
                      <text class="action-text">取消发布</text>
                    </view>
                    <view class="action-item on-sale" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transferring">
                      <text class="action-text">退回发布</text>
                    </view>
                    <view class="action-item completed" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transferred">
                      <text class="action-text">已转让</text>
                    </view>
                  </view>
                  
                  <!-- 已转让 -->
                  <view wx:if="{{item.transferStatus === 'transferred'}}">
                    <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                      <text class="action-text">删除</text>
                    </view>
                  </view>
                  
                  <!-- 已取消 -->
                  <view wx:if="{{item.transferStatus === 'transfer_cancelled'}}" style="display: flex; flex-direction: row; gap: 12rpx; align-items: center;">
                    <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                      <text class="action-text">删除</text>
                    </view>
                    <view class="action-item on-sale" bindtap="handleStatusChange" data-id="{{item.id}}" data-status="transferring">
                      <text class="action-text">重新发布</text>
                    </view>
                  </view>
                </view>
                
                <!-- 审核中的物品操作 -->
                <view wx:if="{{item.status === 'auditing'}}">
                  <view class="action-item delete" bindtap="handleDelete" data-id="{{item.id}}">
                    <text class="action-text">删除</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>


    </view>
  </view>
</view>
