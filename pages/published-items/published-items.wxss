/* pages/published-items/published-items.wxss */

.published-items-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

/* Stats Section */
.stats-section {
  padding: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
}

.stat-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: bold;
  color: #0ea5e9;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
}

/* Items List */
.items-list {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 16rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.empty-btn {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #0ea5e9;
  color: white;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

/* Item Card */
.item-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: visible;
  position: relative;
}

/* Item View */
.item-view {
  padding: 12rpx;
}

.item-header {
  display: flex;
  gap: 12rpx;
}

.item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
}

.item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.item-menu {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background-color: #f3f4f6;
  cursor: pointer;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 30rpx;
  color: #9ca3af;
}

.item-date {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.item-badges {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.item-price {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #f97316;
}

.status-badge {
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: white;
}

.status-badge.status-on-sale {
  background-color: #10b981;
}

.status-badge.status-offline {
  background-color: #9ca3af;
}

.status-badge.status-trading {
  background-color: #0ea5e9;
}

.status-badge.status-completed {
  background-color: #a855f7;
}

.review-status {
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.review-status.review-pending {
  background-color: #fef3c7;
  color: #92400e;
}

.review-status.review-approved {
  background-color: #dcfce7;
  color: #166534;
}

.review-status.review-rejected {
  background-color: #fee2e2;
  color: #991b1b;
}

.rejection-reason {
  padding: 8rpx;
  background-color: #fee2e2;
  border-radius: 4rpx;
  margin-top: 4rpx;
}

.reason-label {
  display: block;
  font-size: 22rpx;
  color: #991b1b;
  font-weight: 600;
}

.item-stats {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.stat-item {
  display: inline-block;
}

/* Menu */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
}

.menu-popup-wrapper {
  position: absolute;
  right: 0;
  top: 32rpx;
  z-index: 100;
}

.menu-popup {
  position: absolute;
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  z-index: 100;
  min-width: 190rpx;
  right: 0;
  top: 0;
}

.menu-item {
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
  color: #1f2937;
  cursor: pointer;
  transition: background-color 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9fafb;
}

.menu-item.delete {
  color: #dc2626;
}

.menu-item.delete:active {
  background-color: #fee2e2;
}

/* Item Edit */
.item-edit {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.form-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #1f2937;
}

.form-input {
  padding: 8rpx 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #1f2937;
  min-height: 40rpx;
}

.form-input.picker {
  display: flex;
  align-items: center;
}

.form-textarea {
  padding: 8rpx 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #1f2937;
  min-height: 100rpx;
}

/* Location Display */
.location-display {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  padding: 8rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.location-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  text-align: center;
}

.location-label {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

.location-value {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #1f2937;
}

.location-btn {
  padding: 8rpx 12rpx;
  background-color: #0ea5e9;
  color: white;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
}

/* Image Preview */
.image-preview {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.preview-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.upload-btn {
  padding: 8rpx 12rpx;
  background-color: #f3f4f6;
  color: #1f2937;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  cursor: pointer;
}

/* Edit Actions */
.edit-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.btn {
  flex: 1;
  padding: 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}

.btn-save {
  background-color: #10b981;
  color: white;
}

.btn-save:active {
  background-color: #059669;
}

.btn-cancel {
  background-color: #e5e7eb;
  color: #1f2937;
}

.btn-cancel:active {
  background-color: #d1d5db;
}


/* Status Modal */
.status-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.status-modal {
  width: 100%;
  background-color: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
  padding-bottom: 16rpx;
}

.modal-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.modal-content {
  margin-bottom: 24rpx;
}

.status-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.status-option {
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.status-option.on-sale {
  background-color: #dcfce7;
  color: #166534;
  font-weight: 600;
}

.status-option.on-sale:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.status-option.off-shelf {
  background-color: #f3f4f6;
  color: #6b7280;
  font-weight: 600;
}

.status-option.off-shelf:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.status-option.trading {
  background-color: #dbeafe;
  color: #0c4a6e;
  font-weight: 600;
}

.status-option.trading:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.status-option.sold {
  background-color: #e9d5ff;
  color: #6b21a8;
  font-weight: 600;
}

.status-option.sold:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.option-label {
  display: block;
  font-size: 26rpx;
}

.modal-footer {
  display: flex;
  gap: 12rpx;
}

.btn-close {
  flex: 1;
  padding: 16rpx;
  background-color: #e5e7eb;
  color: #1f2937;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-close:active {
  background-color: #d1d5db;
  transform: scale(0.98);
}
