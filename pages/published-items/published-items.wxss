/* pages/published-items/published-items.wxss */

.published-items-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* Safety Tip */
.safety-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  margin: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #93c5fd;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #1e40af;
  font-weight: 500;
  line-height: 1.5;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

/* Stats Section */
.stats-section {
  padding: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
}

.stat-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: bold;
  color: #0ea5e9;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
}

/* Items List */
.items-list {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 16rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.empty-btn {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #0ea5e9;
  color: white;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

/* Item Card */
.item-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: visible;
  position: relative;
}

/* Item View */
.item-view {
  padding: 12rpx;
}

.item-header {
  display: flex;
  gap: 12rpx;
}

.item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
}

.item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}



.item-date {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.item-badges {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.item-price {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #f97316;
}

.status-badge {
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: white;
}

.status-badge.status-pending-transfer {
  background-color: #10b929ff;
}

.status-badge.status-transferring {
  background-color: #07ac75ff;
}

.status-badge.status-cancelled {
  background-color: #9ca3af;
}

.status-badge.status-accepted {
  background-color: #0ea5e9;
}

.status-badge.status-transferred {
  background-color: #a855f7;
}

.review-status {
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.review-status.review-pending {
  background-color: #fef3c7;
  color: #92400e;
}

.review-status.review-approved {
  background-color: #dcfce7;
  color: #166534;
}

.review-status.review-rejected {
  background-color: #fee2e2;
  color: #991b1b;
}

.rejection-reason {
  padding: 8rpx;
  background-color: #fee2e2;
  border-radius: 4rpx;
  margin-top: 4rpx;
}

.reason-label {
  display: block;
  font-size: 22rpx;
  color: #991b1b;
  font-weight: 600;
}

.item-stats {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.stat-item {
  display: inline-block;
}

/* Item Actions */
.item-actions {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f3f4f6;
  margin-top: 8rpx;
}

.actions-left {
  flex-shrink: 0;
}

.item-actions .item-date {
  font-size: 22rpx;
  color: #9ca3af;
}

.actions-right {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

/* Action Item */
.action-item {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background-color: #f9fafb;
  border: 1rpx solid #e5e7eb;
  cursor: pointer;
  transition: all 0.2s;
}

.action-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-item.delete {
  background: linear-gradient(135deg, #fff1f2 0%, #fee2e2 100%);
  border: 1rpx solid #fca5a5;
}

.action-item.delete:active {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
}

.action-item.completed {
  background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);
  border: 1rpx solid #a78bfa;
}

.action-item.completed:active {
  background: linear-gradient(135deg, #ddd6fe 0%, #c4b5fd 100%);
}

.action-item.offline {
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  border: 1rpx solid #d1d5db;
}

.action-item.offline:active {
  background: linear-gradient(135deg, #e5e7eb 100%, #d1d5db 100%);
}

.action-item.on-sale {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
  border: 1rpx solid #86efac;
}

.action-item.on-sale:active {
  background: linear-gradient(135deg, #bbf7d0 0%, #86efac 100%);
}

.action-item.accepted {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  border: 1rpx solid #60a5fa;
}

.action-item.accepted:active {
  background: linear-gradient(135deg, #bfdbfe 0%, #60a5fa 100%);
}

.action-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #374151;
}

.action-item.delete .action-text {
  color: #dc2626;
}

.action-item.completed .action-text {
  color: #7c3aed;
}

.action-item.offline .action-text {
  color: #6b7280;
}

.action-item.on-sale .action-text {
  color: #16a34a;
}

.action-item.accepted .action-text {
  color: #2563eb;
}

.action-hint {
  display: block;
  font-size: 18rpx;
  color: #64748b;
  margin-top: 4rpx;
  opacity: 0.8;
}



/* Item Edit */
.item-edit {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.form-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #1f2937;
}

.form-input {
  padding: 8rpx 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #1f2937;
  min-height: 40rpx;
}

.form-input.picker {
  display: flex;
  align-items: center;
}

.form-textarea {
  padding: 8rpx 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #1f2937;
  min-height: 100rpx;
}

/* Location Display */
.location-display {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  padding: 8rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.location-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  text-align: center;
}

.location-label {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

.location-value {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #1f2937;
}

.location-btn {
  padding: 8rpx 12rpx;
  background-color: #0ea5e9;
  color: white;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
}

/* Image Preview */
.image-preview {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.preview-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.upload-btn {
  padding: 8rpx 12rpx;
  background-color: #f3f4f6;
  color: #1f2937;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  cursor: pointer;
}

/* Edit Actions */
.edit-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.btn {
  flex: 1;
  padding: 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}

.btn-save {
  background-color: #10b981;
  color: white;
}

.btn-save:active {
  background-color: #059669;
}

.btn-cancel {
  background-color: #e5e7eb;
  color: #1f2937;
}

.btn-cancel:active {
  background-color: #d1d5db;
}
