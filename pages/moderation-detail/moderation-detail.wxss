page {
  background-color: #f9fafb;
}

.detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  z-index: 10;
  position: sticky;
  top: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.header-subtitle {
  font-size: 20rpx;
  color: #9ca3af;
  font-weight: 500;
}

/* Content Scroll */
.content-scroll {
  flex: 1;
  overflow-y: auto;
}

/* Alert Box */
.alert-box {
  display: flex;
  gap: 12rpx;
  background-color: #fef3c7;
  border: 1rpx solid #fcd34d;
  border-radius: 8rpx;
  padding: 12rpx;
  margin: 16rpx;
}

.alert-icon {
  font-size: 24rpx;
  color: #b45309;
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
  display: block;
  margin-bottom: 4rpx;
}

.alert-reason {
  font-size: 26rpx;
  color: #b45309;
  display: block;
  margin-bottom: 6rpx;
}

.alert-issues {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.alert-issue {
  font-size: 24rpx;
  color: #b45309;
}

/* Images Section */
.images-section {
  background-color: white;
  padding: 12rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

/* Main Image Container */
.main-image-container {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.main-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #f3f4f6;
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.image-counter {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.image-nav {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 0 12rpx;
  transform: translateY(-50%);
}

.nav-btn {
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1f2937;
}

/* Thumbnail Strip */
.thumbnail-strip {
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.thumbnail {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #e5e7eb;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
}

.thumbnail image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #f3f4f6;
}

.thumbnail-active {
  border-color: #10b981;
}

/* Info Section */
.info-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.info-item:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.info-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #9ca3af;
  margin-bottom: 6rpx;
  display: block;
}

.info-value {
  font-size: 26rpx;
  color: #1f2937;
  display: block;
  line-height: 1.6;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 8rpx 16rpx;
  background-color: #f3f4f6;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

/* Publisher Section */
.publisher-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.publisher-card {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.publisher-avatar {
  width: 48rpx;
  height: 48rpx;
  background-color: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.publisher-details {
  flex: 1;
}

.publisher-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.publisher-level {
  font-size: 20rpx;
  color: #10b981;
  margin-bottom: 2rpx;
}

.publisher-credit {
  font-size: 20rpx;
  color: #9ca3af;
}

.publisher-stats {
  font-size: 20rpx;
  color: #9ca3af;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.publisher-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.publisher-arrow {
  font-size: 24rpx;
  color: #9ca3af;
  margin-left: 12rpx;
}

/* Location Section */
.location-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.location-info {
  margin-top: 12rpx;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.location-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.location-label {
  font-size: 20rpx;
  color: #9ca3af;
}

.location-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background-color: #f3f4f6;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.2s;
}

.location-icon:hover {
  background-color: #e5e7eb;
  transform: scale(1.1);
}

.location-icon text {
  font-size: 24rpx;
}

.location-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

/* Contact Section */
.contact-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.contact-item:last-child {
  margin-bottom: 0;
}

.contact-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.contact-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

.contact-action {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 600;
  cursor: pointer;
  transition: color 0.2s;
}

.contact-action:hover {
  color: #059669;
}

/* Score Section */
.score-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.score-display {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.score-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.score-bar {
  width: 100%;
  height: 12rpx;
  background-color: #e5e7eb;
  border-radius: 6rpx;
  overflow: hidden;
  margin: 8rpx 0;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6 0%, #10b981 100%);
  transition: width 0.3s;
}

.score-text {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  line-height: 1.4;
}

/* Review Section */
.review-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.form-group {
  margin-bottom: 20rpx;
  margin-top: 12rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.required {
  color: #f97316;
}

.form-buttons {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.form-btn {
  flex: 1;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e5e7eb;
  background-color: white;
  color: #6b7280;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}

.form-btn.active {
  background-color: #10b981;
  color: white;
  border-color: #10b981;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.form-btn:active {
  transform: scale(0.98);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #1f2937;
  box-sizing: border-box;
  resize: vertical;
  line-height: 1.6;
}

.char-count {
  font-size: 20rpx;
  color: #9ca3af;
  display: block;
  margin-top: 8rpx;
  text-align: right;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  margin-bottom: 20rpx;
}

.btn {
  flex: 1;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: none;
  color: white;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
}

.btn-cancel {
  background-color: #e5e7eb;
  color: #1f2937;
}

.btn-submit {
  background-color: #10b981;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.btn:active {
  transform: scale(0.98);
}

/* Status Section */
.status-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.status-display {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.status-badge {
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.status-badge.approved {
  background-color: #d1fae5;
  color: #10b981;
  border: 2rpx solid #bbf7d0;
}

.status-badge.rejected {
  background-color: #fee2e2;
  color: #dc2626;
  border: 2rpx solid #fecaca;
}

.status-time {
  font-size: 20rpx;
  color: #6b7280;
  display: block;
  text-align: center;
  margin-top: 4rpx;
}

/* Footer Spacing */
.footer-spacing {
  height: 40rpx;
}
