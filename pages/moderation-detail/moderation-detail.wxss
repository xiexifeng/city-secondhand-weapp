page {
  background-color: #f3f4f6;
}

.detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f3f4f6;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  padding-top: 32rpx;
  z-index: 10;
  position: sticky;
  top: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.header-subtitle {
  font-size: 12rpx;
  color: #9ca3af;
}

/* Content Scroll */
.content-scroll {
  flex: 1;
  overflow-y: auto;
}

/* Alert Box */
.alert-box {
  display: flex;
  gap: 12rpx;
  background-color: #fef3c7;
  border: 1rpx solid #fcd34d;
  border-radius: 8rpx;
  padding: 12rpx;
  margin: 16rpx;
}

.alert-icon {
  font-size: 24rpx;
  color: #b45309;
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.alert-title {
  font-size: 14rpx;
  font-weight: 600;
  color: #92400e;
  display: block;
  margin-bottom: 4rpx;
}

.alert-reason {
  font-size: 12rpx;
  color: #b45309;
  display: block;
  margin-bottom: 6rpx;
}

.alert-issues {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.issue-item {
  font-size: 11rpx;
  color: #b45309;
}

/* Images Section */
.images-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.section-title {
  font-size: 14rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.images-scroll {
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
}

.image-item {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.image-item image {
  width: 100%;
  height: 100%;
}

/* Info Section */
.info-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 12rpx;
  font-weight: 600;
  color: #9ca3af;
  margin-bottom: 4rpx;
  display: block;
}

.info-value {
  font-size: 14rpx;
  color: #1f2937;
  display: block;
  line-height: 1.5;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  background-color: #dbeafe;
  color: #0c4a6e;
  border-radius: 4rpx;
  font-size: 12rpx;
}

/* Publisher Section */
.publisher-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.publisher-card {
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.publisher-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #0ea5e9;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.publisher-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.publisher-name {
  font-size: 14rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
}

.publisher-level {
  font-size: 12rpx;
  color: #0ea5e9;
  display: block;
  margin-top: 2rpx;
}

.publisher-credit {
  font-size: 11rpx;
  color: #9ca3af;
  display: block;
  margin-top: 2rpx;
}

/* Score Section */
.score-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.score-bar {
  width: 100%;
  height: 8rpx;
  background-color: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
  margin: 8rpx 0;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #0ea5e9 0%, #10b981 100%);
  transition: width 0.3s;
}

.score-text {
  font-size: 12rpx;
  color: #6b7280;
  display: block;
}

/* Review Section */
.review-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.form-group {
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 12rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.required {
  color: #f97316;
}

.form-textarea {
  width: 100%;
  min-height: 100rpx;
  padding: 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 14rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.char-count {
  font-size: 11rpx;
  color: #9ca3af;
  display: block;
  margin-top: 4rpx;
  text-align: right;
}

.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.btn {
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  font-size: 14rpx;
  font-weight: 600;
  border: none;
  color: white;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-approve {
  background-color: #10b981;
}

.btn-approve:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-reject {
  background-color: #dc2626;
}

.btn-reject:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* Status Display */
.status-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 16rpx;
  text-align: center;
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: white;
  margin-bottom: 16rpx;
}

.status-icon.approved {
  background-color: #10b981;
}

.status-icon.rejected {
  background-color: #dc2626;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.status-points {
  font-size: 14rpx;
  color: #9ca3af;
  display: block;
}

/* Footer Spacing */
.footer-spacing {
  height: 40rpx;
}
