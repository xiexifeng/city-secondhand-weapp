page {
  background-color: #f3f4f6;
}

.detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f3f4f6;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  z-index: 10;
  position: sticky;
  top: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.header-subtitle {
  font-size: 16rpx;
  color: #9ca3af;
  font-weight: 500;
}

/* Content Scroll */
.content-scroll {
  flex: 1;
  overflow-y: auto;
}

/* Alert Box */
.alert-box {
  display: flex;
  gap: 12rpx;
  background-color: #fef3c7;
  border: 1rpx solid #fcd34d;
  border-radius: 8rpx;
  padding: 12rpx;
  margin: 16rpx;
}

.alert-icon {
  font-size: 24rpx;
  color: #b45309;
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.alert-title {
  font-size: 18rpx;
  font-weight: 600;
  color: #92400e;
  display: block;
  margin-bottom: 4rpx;
}

.alert-reason {
  font-size: 16rpx;
  color: #b45309;
  display: block;
  margin-bottom: 6rpx;
}

.alert-issues {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.alert-issue {
  font-size: 14rpx;
  color: #b45309;
}

/* Images Section */
.images-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

/* Main Image Container */
.main-image-container {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.main-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #f3f4f6;
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.image-counter {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.image-nav {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 0 12rpx;
  transform: translateY(-50%);
}

.nav-btn {
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1f2937;
}

/* Thumbnail Strip */
.thumbnail-strip {
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.thumbnail {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #e5e7eb;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
}

.thumbnail image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #f3f4f6;
}

.thumbnail-active {
  border-color: #10b981;
}

/* Info Section */
.info-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.info-item:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.info-label {
  font-size: 14rpx;
  font-weight: 600;
  color: #9ca3af;
  margin-bottom: 4rpx;
  display: block;
}

.info-value {
  font-size: 18rpx;
  color: #1f2937;
  display: block;
  line-height: 1.6;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 14rpx;
  background-color: #dbeafe;
  color: #0c4a6e;
  border-radius: 4rpx;
  font-size: 14rpx;
}

/* Publisher Section */
.publisher-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.publisher-card {
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.publisher-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #0ea5e9;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.publisher-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.publisher-name {
  font-size: 18rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
}

.publisher-level {
  font-size: 14rpx;
  color: #0ea5e9;
  display: block;
  margin-top: 2rpx;
}

.publisher-credit {
  font-size: 13rpx;
  color: #9ca3af;
  display: block;
  margin-top: 2rpx;
}

/* Score Section */
.score-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.score-display {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.score-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.score-bar {
  width: 100%;
  height: 8rpx;
  background-color: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
  margin: 8rpx 0;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #0ea5e9 0%, #10b981 100%);
  transition: width 0.3s;
}

.score-text {
  font-size: 14rpx;
  color: #6b7280;
  display: block;
}

/* Review Section */
.review-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.form-group {
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 18rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.required {
  color: #f97316;
}

.form-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.form-btn {
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e5e7eb;
  background-color: white;
  color: #6b7280;
  font-size: 16rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
}

.form-btn.active {
  background-color: #10b981;
  color: white;
  border-color: #10b981;
}

.form-textarea {
  width: 100%;
  min-height: 100rpx;
  padding: 12rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 16rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.char-count {
  font-size: 13rpx;
  color: #9ca3af;
  display: block;
  margin-top: 4rpx;
  text-align: right;
}

.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.btn {
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 600;
  border: none;
  color: white;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-cancel {
  background-color: #e5e7eb;
  color: #1f2937;
}

.btn-submit {
  background-color: #10b981;
  color: white;
}

/* Status Section */
.status-section {
  background-color: white;
  padding: 16rpx;
  margin: 12rpx 16rpx;
  border-radius: 8rpx;
}

.status-display {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.status-badge {
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 600;
  text-align: center;
}

.status-badge.approved {
  background-color: #dcfce7;
  color: #15803d;
}

.status-badge.rejected {
  background-color: #fee2e2;
  color: #dc2626;
}

.status-time {
  font-size: 14rpx;
  color: #6b7280;
  display: block;
  text-align: center;
}

/* Footer Spacing */
.footer-spacing {
  height: 40rpx;
}
