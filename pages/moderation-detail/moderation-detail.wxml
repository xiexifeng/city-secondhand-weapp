<!--pages/moderation-detail/moderation-detail.wxml-->
<view class="detail-container">
  <!-- Content -->
  <scroll-view scroll-y class="content-scroll">
    <!-- Status Alert -->
    <view wx:if="{{detail.reason}}" class="alert-box">
      <text class="alert-icon">⚠</text>
      <view class="alert-content">
        <text class="alert-title">机器审核标记</text>
        <text class="alert-reason">{{detail.reason}}</text>
        <view class="alert-issues">
          <view wx:for="{{detail.issues}}" wx:key="index" class="alert-issue">
            • {{item}}
          </view>
        </view>
      </view>
    </view>

    <!-- Machine Score Section -->
    <view class="score-section">
      <text class="section-title">机器审核评分</text>
      <view class="score-display">
        <view class="score-value">{{detail.machineScore}}</view>
        <view class="score-bar">
          <view class="score-fill" style="width: {{detail.machineScore}}%"></view>
        </view>
        <text class="score-text">综合风险评分（0-100，分数越高风险越大）</text>
      </view>
    </view>

    <!-- Images Gallery -->
    <view class="images-section">
      <text class="section-title">图片</text>
      
      <!-- Main Image -->
      <view class="main-image-container">
        <image 
          class="main-image" 
          src="{{detail.images[currentImageIndex]}}"
          mode="aspectFill"
          lazy-load="true"
        />
        <view class="image-counter">
          {{currentImageIndex + 1}}/{{detail.images.length}}
        </view>
        <view wx:if="{{detail.images.length > 1}}" class="image-nav">
          <view class="nav-btn nav-prev" bindtap="handlePrevImage">
            <text>‹</text>
          </view>
          <view class="nav-btn nav-next" bindtap="handleNextImage">
            <text>›</text>
          </view>
        </view>
      </view>

      <!-- Thumbnail Strip -->
      <view wx:if="{{detail.images.length > 1}}" class="thumbnail-strip">
        <view 
          wx:for="{{detail.images}}" 
          wx:key="index"
          class="thumbnail {{currentImageIndex === index ? 'thumbnail-active' : ''}}"
          bindtap="handleSelectImage"
          data-index="{{index}}"
        >
          <image src="{{item}}" mode="aspectFill" lazy-load="true" />
        </view>
      </view>
    </view>

    <!-- Content Info -->
    <view class="info-section">
      <text class="section-title">内容信息</text>
      
      <view class="info-item">
        <text class="info-label">标题</text>
        <text class="info-value">{{detail.title}}</text>
      </view>

      <view class="info-item">
        <text class="info-label">类型</text>
        <text class="info-value">{{detail.type === 'item' ? '物品' : '心愿'}}</text>
      </view>

      <view class="info-item">
        <text class="info-label">分类</text>
        <text class="info-value">{{detail.category}}</text>
      </view>

      <view class="info-item">
        <text class="info-label">描述</text>
        <text class="info-value">{{detail.description}}</text>
      </view>

      <view wx:if="{{detail.price}}" class="info-item">
        <text class="info-label">价格</text>
        <text class="info-value">{{detail.price}}</text>
      </view>

      <view wx:if="{{detail.exchangeMethod}}" class="info-item">
        <text class="info-label">交换方式</text>
        <text class="info-value">{{detail.exchangeMethod}}</text>
      </view>

      <view class="info-item">
        <text class="info-label">标签</text>
        <view class="tags-list">
          <view wx:for="{{detail.tags}}" wx:key="index" class="tag">{{item}}</view>
        </view>
      </view>
    </view>

    <!-- Publisher Section -->
    <view class="publisher-section">
      <text class="section-title">发布者信息</text>
      <view class="publisher-card">
        <view class="publisher-avatar">{{detail.publisher.avatar}}</view>
        <view class="publisher-details">
          <view class="publisher-name">
            {{detail.publisher.name}}
            <view wx:if="{{detail.publisher.verified}}" class="tag tag-verified">已实名</view>
          </view>
          <view class="publisher-stats">
            <text>发布了 {{detail.publisher.items}} 件物品</text>
            <text>已转让率: {{detail.publisher.transferRate}}%</text>
          </view>
        </view>
        <view class="publisher-actions">
          <view class="publisher-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- Location Section -->
    <view class="location-section">
      <text class="section-title">交易地点</text>
      <view class="location-info">
        <view class="location-header">
          <text class="location-label">位置信息</text>
          <view class="location-icon" bindtap="navigateToMap">
            <text>📍</text>
          </view>
        </view>
        <text class="location-value">{{detail.location}}</text>
      </view>
    </view>

    <!-- Contact Section -->
    <view class="contact-section">
      <text class="section-title">联系方式</text>
      <view class="contact-item">
        <view class="contact-icon">📱</view>
        <view class="contact-info">
          <text class="contact-label">手机号码</text>
          <text class="contact-value">{{detail.contact.phone}}</text>
        </view>
        <view class="contact-action" bindtap="copyPhone">复制</view>
      </view>
      <view class="contact-item">
        <view class="contact-icon">💬</view>
        <view class="contact-info">
          <text class="contact-label">微信</text>
          <text class="contact-value">{{detail.contact.wechat}}</text>
        </view>
        <view class="contact-action" bindtap="copyWechat">复制</view>
      </view>
    </view>

    <!-- Review Section (if pending) -->
    <view wx:if="{{detail.status === 'pending'}}" class="review-section">
      <text class="section-title">审核意见</text>
      
      <view class="form-group">
        <text class="form-label">审核结论 <text class="required">*</text></text>
        <view class="form-buttons">
          <view class="form-btn {{reviewStatus === 'approve' ? 'active' : ''}}" bindtap="setReviewStatus" data-status="approve">
            ✓ 通过
          </view>
          <view class="form-btn {{reviewStatus === 'reject' ? 'active' : ''}}" bindtap="setReviewStatus" data-status="reject">
            ✕ 拒绝
          </view>
        </view>
      </view>

      <view wx:if="{{reviewStatus === 'reject'}}" class="form-group">
        <text class="form-label">拒绝原因 <text class="required">*</text></text>
        <textarea 
          class="form-textarea" 
          placeholder="请输入拒绝原因..."
          value="{{rejectReason}}"
          bindinput="onRejectReasonChange"
          maxlength="200"
        />
        <text class="char-count">{{rejectReason.length}}/200</text>
      </view>

      <view class="action-buttons">
        <!-- <view class="btn btn-cancel" bindtap="goBack">取消</view> -->
        <view class="btn btn-submit" bindtap="handleSubmitReview" wx:if="{{reviewStatus}}">提交审核</view>
      </view>
    </view>

    <!-- Status Display (if not pending) -->
    <view wx:else class="status-section">
      <text class="section-title">审核状态</text>
      <view class="status-display">
        <view class="status-badge {{detail.status === 'approved' ? 'approved' : 'rejected'}}">
          {{detail.status === 'approved' ? '✓ 已通过' : '✕ 已拒绝'}}
        </view>
        <text class="status-time">审核时间: {{detail.reviewedAt}}</text>
      </view>
    </view>

    <!-- Footer Spacing -->
    <view class="footer-spacing"></view>
  </scroll-view>
</view>
