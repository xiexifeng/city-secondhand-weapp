<!--pages/messages/messages.wxml-->
<view class="messages-container">
  <!-- 顶部导航栏 -->
  <view class="messages-header">
    <view class="header-left">
      <view class="back-btn" bindtap="handleBack">
        <text>←</text>
      </view>
    </view>
    <view class="header-content">
      <text class="header-title">消息中心</text>
      <text wx:if="{{unreadCount > 0}}" class="header-subtitle">{{unreadCount}} 条未读消息</text>
    </view>
    <view class="header-right"></view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-container">
    <view class="stat-card" bindtap="setActiveFilter" data-filter="all">
      <text class="stat-number">{{messages.length}}</text>
      <text class="stat-label">全部消息</text>
    </view>
    <view class="stat-card" bindtap="setActiveFilter" data-filter="unread">
      <text class="stat-number warning">{{unreadCount}}</text>
      <text class="stat-label">未读消息</text>
    </view>
    <view class="stat-card" bindtap="setActiveFilter" data-filter="report">
      <text class="stat-number danger">{{reportCount}}</text>
      <text class="stat-label">举报投诉</text>
    </view>
    <view class="stat-card" bindtap="setActiveFilter" data-filter="moderation">
      <text class="stat-number info">{{moderationCount}}</text>
      <text class="stat-label">内容审核</text>
    </view>
  </view>

  <!-- 筛选标签 -->
  <scroll-view class="filter-tabs" scroll-x>
    <view class="filter-tab {{activeFilter === 'all' ? 'active' : ''}}" bindtap="setActiveFilter" data-filter="all">
      全部
    </view>
    <view class="filter-tab {{activeFilter === 'unread' ? 'active' : ''}}" bindtap="setActiveFilter" data-filter="unread">
      未读
    </view>
    <view class="filter-tab {{activeFilter === 'report' ? 'active' : ''}}" bindtap="setActiveFilter" data-filter="report">
      举报 ({{pendingReportCount}})
    </view>
    <view class="filter-tab {{activeFilter === 'moderation' ? 'active' : ''}}" bindtap="setActiveFilter" data-filter="moderation">
      内容审核
    </view>
  </scroll-view>

  <!-- 消息列表 -->
  <scroll-view class="messages-list" scroll-y>
    <view wx:if="{{filteredMessages.length > 0}}" class="messages-content">
      <view wx:for="{{filteredMessages}}" wx:key="id" class="message-item {{item.read ? '' : 'unread'}}" bindtap="handleMessageClick" data-id="{{item.id}}" data-type="{{item.type}}" data-report-id="{{item.report ? item.report.id : ''}}">
        <!-- 消息图标 -->
        <view class="message-icon {{item.type}}">
          <text wx:if="{{item.type === 'report'}}">🚩</text>
          <text wx:if="{{item.type === 'moderation'}}">✓</text>
          <text wx:if="{{item.type === 'alert'}}">⚠️</text>
          <text wx:if="{{item.type === 'system'}}">🕐</text>
          <text wx:if="{{item.type === 'activity'}}">💬</text>
        </view>

        <!-- 消息内容 -->
        <view class="message-content">
          <view class="message-header">
            <text class="message-title">{{item.title}}</text>
            <view wx:if="{{!item.read}}" class="unread-dot"></view>
          </view>
          <text class="message-description">{{item.description}}</text>

          <!-- 举报状态标签 -->
          <view wx:if="{{item.type === 'report' && item.report}}" class="message-status">
            <text class="status-badge {{getStatusClass(item.report.status)}}">{{item.report.status}}</text>
            <text class="status-date">{{formatDate(item.createdAt)}}</text>
          </view>
        </view>

        <!-- 删除按钮 -->
        <view class="message-delete" bindtap="deleteMessage" data-id="{{item.id}}" catch:tap>
          <text>🗑️</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-text">暂无消息</text>
    </view>
  </scroll-view>

  <!-- 举报详情弹窗 -->
  <view wx:if="{{selectedReport}}" class="modal-overlay" bindtap="closeReportModal">
    <view class="modal-content" catch:tap>
      <!-- 弹窗头部 -->
      <view class="modal-header">
        <text class="modal-title">{{selectedReport.type === 'item' ? '物品举报' : '用户投诉'}}详情</text>
        <view class="modal-close" bindtap="closeReportModal">✕</view>
      </view>

      <!-- 弹窗内容 -->
      <scroll-view class="modal-body" scroll-y>
        <!-- 被举报对象 -->
        <view class="modal-section">
          <text class="section-label">被举报对象</text>
          <text class="section-value">{{selectedReport.targetName}}</text>
        </view>

        <!-- 举报原因 -->
        <view class="modal-section">
          <text class="section-label">举报原因</text>
          <text class="section-value">{{selectedReport.reason}}</text>
        </view>

        <!-- 详细描述 -->
        <view class="modal-section">
          <text class="section-label">详细描述</text>
          <text class="section-value">{{selectedReport.description}}</text>
        </view>

        <!-- 证据图片 -->
        <view wx:if="{{selectedReport.evidence && selectedReport.evidence.length > 0}}" class="modal-section">
          <text class="section-label">证据</text>
          <view class="evidence-grid">
            <image wx:for="{{selectedReport.evidence}}" wx:key="index" src="{{item}}" class="evidence-image" mode="aspectFill" />
          </view>
        </view>

        <!-- 当前状态 -->
        <view class="modal-section">
          <text class="section-label">当前状态</text>
          <text class="section-value {{getStatusClass(selectedReport.status)}}">{{selectedReport.status}}</text>
        </view>

        <!-- 审核处理 -->
        <view wx:if="{{selectedReport.status === '待审核'}}" class="review-section">
          <text class="review-title">审核处理</text>
          
          <textarea 
            class="review-textarea"
            placeholder="输入审核备注（可选）..."
            value="{{reviewNote}}"
            bindinput="updateReviewNote"
          />

          <view class="review-buttons">
            <button class="review-btn valid" bindtap="handleReviewReport" data-status="有效">
              ✓ 标记为有效
            </button>
            <button class="review-btn invalid" bindtap="handleReviewReport" data-status="无效">
              ✕ 标记为无效
            </button>
            <button class="review-btn handled" bindtap="handleReviewReport" data-status="已处理">
              🕐 已处理
            </button>
          </view>
        </view>
      </scroll-view>

      <!-- 关闭按钮 -->
      <view class="modal-footer">
        <button class="close-btn" bindtap="closeReportModal">关闭</button>
      </view>
    </view>
  </view>

</view>
