/* pages/messages/messages.wxss */

page {
  background-color: #f9fafb;
}

.messages-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}

/* Header */
.messages-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  z-index: 10;
  position: sticky;
  top: 0;
}

.header-left,
.header-right {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  transition: background-color 0.2s;
}

.back-btn:active {
  background-color: #f3f4f6;
}

.back-btn text {
  font-size: 24rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-content {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #0ea5e9;
}

.header-subtitle {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 2rpx;
}

/* Stats Cards */
.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 16rpx;
  background-color: #f9fafb;
}

.stat-card {
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  transition: all 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-card:active {
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.stat-number {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #0ea5e9;
  margin-bottom: 4rpx;
}

.stat-number.warning {
  color: #f59e0b;
}

.stat-number.danger {
  color: #dc2626;
}

.stat-number.info {
  color: #0ea5e9;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

/* Filter Tabs */
.filter-tabs {
  display: flex;
  padding: 0 16rpx;
  background-color: #f9fafb;
  border-bottom: 1rpx solid #e5e7eb;
  white-space: nowrap;
  overflow-x: auto;
}

.filter-tab {
  padding: 8rpx 16rpx;
  margin-right: 10rpx;
  border-radius: 20rpx;
  background-color: #f3f4f6;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1rpx solid transparent;
  display: inline-flex;
  align-items: center;
  height: 36rpx;
}

.filter-tab.active {
  background-color: #0ea5e9;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(14, 165, 233, 0.3);
}

.filter-tab:active {
  opacity: 0.8;
}

/* Messages List */
.messages-list {
  flex: 1;
  overflow-y: auto;
}

.messages-content {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* Message Item */
.message-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background-color: white;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  transition: all 0.2s;
}

.message-item.unread {
  background-color: #eff6ff;
  border-color: #bfdbfe;
}

.message-item:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* Message Icon */
.message-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  background-color: #f3f4f6;
}

.message-icon.report {
  background-color: #fee2e2;
}

.message-icon.moderation {
  background-color: #dbeafe;
}

.message-icon.alert {
  background-color: #fef3c7;
}

.message-icon.system {
  background-color: #dbeafe;
}

.message-icon.activity {
  background-color: #dbeafe;
}

/* Message Content */
.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.message-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread-dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #0ea5e9;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-description {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* Message Status */
.message-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.status-badge {
  display: inline-block;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-badge.pending {
  background-color: #fef3c7;
  color: #92400e;
}

.status-badge.valid {
  background-color: #fee2e2;
  color: #991b1b;
}

.status-badge.invalid {
  background-color: #dcfce7;
  color: #166534;
}

.status-badge.handled {
  background-color: #dbeafe;
  color: #0c4a6e;
}

.status-date {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
}

/* Delete Button */
.message-delete {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 18rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.message-delete:active {
  background-color: #fee2e2;
}

/* Empty State */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background-color: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  border-bottom: 1rpx solid #e5e7eb;
  flex-shrink: 0;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.modal-close {
  font-size: 28rpx;
  color: #9ca3af;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx;
}

/* Modal Section */
.modal-section {
  background-color: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 12rpx;
  margin-bottom: 12rpx;
}

.section-label {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
  font-weight: 600;
}

.section-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
}

.section-value.pending {
  color: #f59e0b;
}

.section-value.valid {
  color: #dc2626;
}

.section-value.invalid {
  color: #16a34a;
}

.section-value.handled {
  color: #0ea5e9;
}

/* Evidence Grid */
.evidence-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.evidence-image {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

/* Review Section */
.review-section {
  background-color: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 8rpx;
  padding: 12rpx;
  margin-bottom: 12rpx;
}

.review-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.review-textarea {
  width: 100%;
  padding: 12rpx;
  border: 1rpx solid #bfdbfe;
  border-radius: 8rpx;
  background-color: white;
  font-size: 24rpx;
  color: #1f2937;
  box-sizing: border-box;
  min-height: 100rpx;
  margin-bottom: 12rpx;
  resize: none;
}

.review-textarea::placeholder {
  color: #d1d5db;
}

.review-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.review-btn {
  padding: 12rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: white;
  transition: all 0.2s;
}

.review-btn.valid {
  background-color: #dc2626;
}

.review-btn.valid:active {
  background-color: #b91c1c;
}

.review-btn.invalid {
  background-color: #16a34a;
}

.review-btn.invalid:active {
  background-color: #15803d;
}

.review-btn.handled {
  background-color: #0ea5e9;
}

.review-btn.handled:active {
  background-color: #0284c7;
}

/* Modal Footer */
.modal-footer {
  padding: 16rpx;
  border-top: 1rpx solid #e5e7eb;
  flex-shrink: 0;
}

.close-btn {
  width: 100%;
  padding: 16rpx;
  background-color: #f3f4f6;
  color: #1f2937;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.close-btn:active {
  background-color: #e5e7eb;
}
