/* 颜色系统 - 完全还原原项目 */
/* Primary: Deep Slate Blue #1F2937 */
/* Success: Emerald Green #10B981 */
/* Warning: Warm Orange #F97316 */

page {
  background-color: #ffffff;
}

.home-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ffffff;
}

/* ========== 登录提示横幅 ========== */
.login-banner {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
  padding: 16rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.2);
}

.login-banner-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.login-banner-title {
  font-size: 28rpx;
  font-weight: 700;
  color: white;
  display: block;
}

.login-banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

.login-banner-btn {
  padding: 10rpx 20rpx;
  background-color: white;
  color: #10b981;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  transition: all 0.2s;
}

.login-banner-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== 顶部搜索栏 ========== */
.search-bar {
  background-color: white;
  padding: 12rpx 16rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.08);
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #eef2f7;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #F8FAFC;
  border-radius: 20rpx;
  padding: 10rpx 16rpx;
  gap: 8rpx;
}

.search-icon {
  font-size: 20rpx;
  color: #6B7280;
}

.search-placeholder {
  flex: 1;
  background: transparent;
  border: none;
  font-size: 28rpx;
  color: #475569;
  padding: 0;
}

.search-placeholder::placeholder {
  color: #94A3B8;
}

.filter-btn {
  width: 92rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0fdf4;
  border-radius: 8rpx;
  color: #059669;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #bbf7d0;
}

/* ========== 筛选标签栏 ========== */
.filter-tags {
  background-color: white;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #EEF2F7;
  box-shadow: 0 1rpx 2rpx rgba(15, 23, 42, 0.03);
}

.tags-scroll {
  display: flex;
  padding: 0 16rpx;
  white-space: nowrap;
}

.tag-item {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-right: 12rpx;
  border: 1rpx solid #EEF2F7;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
  background-color: white;
  transition: all 0.2s;
  white-space: nowrap;
}

.tag-item:active {
  transform: scale(0.95);
}

.tag-item.tag-active {
  background-color: #10B981;
  color: white;
  border-color: #10B981;
}

/* ========== 物品列表容器 ========== */
.items-container {
  flex: 1;
  overflow-y: auto;
  padding: 12rpx 12rpx 24rpx;
  background-color: #ffffff;
}

.items-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

/* ========== 物品卡片 ========== */
.item-card {
  background-color: white;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #EEF2F7;
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.06);
  transition: all 0.2s;
}

.item-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.12);
}

/* 图片容器 - 优化加载性能 */
.item-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
  background: linear-gradient(135deg, #F8FAFC 0%, #EEF2F7 100%);
  /* 使用占位图背景，提升加载体验 */
}

.item-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  /* 启用图片懒加载，通过WXML中的lazy-load属性 */
  background-color: #F8FAFC;
}

/* 图片加载中状态 */
.item-image.loading {
  opacity: 0.5;
}

/* 图片加载完成状态 */
.item-image.loaded {
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 急出标签 */
.item-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background-color: #F97316;
  color: white;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 收藏按钮 */
.item-favorite {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  font-size: 20rpx;
}

/* 卡片信息 */
.item-info {
  padding: 12rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

/* 价格和距离行 */
.item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.item-price {
  font-weight: 700;
  color: #F97316;
}

.item-price-zero {
  font-weight: 700;
  color: #10B981;
}

.item-distance {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 标签和交易方式 */
.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  gap: 8rpx;
}

.item-tags {
  display: flex;
  gap: 4rpx;
  flex: 1;
  overflow: hidden;
}

.item-tag {
  background-color: #F8FAFC;
  color: #475569;
  padding: 2rpx 6rpx;
  border-radius: 3rpx;
  font-size: 20rpx;
  white-space: nowrap;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-type {
  background-color: #10B981;
  color: white;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ========== 加载状态 ========== */
.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 20rpx;
  color: #64748B;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #E5E7EB;
  border-top-color: #10B981;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.loading-more {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #64748B;
}

.spinner {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #E5E7EB;
  border-top-color: #10B981;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.no-more {
  color: #D1D5DB;
  font-size: 24rpx;
}

/* ========== 审核Icon ========== */
.audit-icon-wrapper {
  position: fixed;
  bottom: calc(110rpx + env(safe-area-inset-bottom));
  right: 20rpx;
  width: 86rpx;
  height: 86rpx;
  background-color: #F97316;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 16rpx rgba(249, 115, 22, 0.3);
  z-index: 5;
}

.audit-icon-text {
  font-size: 44rpx;
  font-weight: bold;
}

.audit-icon-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  min-width: 38rpx;
  height: 38rpx;
  background-color: #dc2626;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: bold;
  border: 3rpx solid white;
}
