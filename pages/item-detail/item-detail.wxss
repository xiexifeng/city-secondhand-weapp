page {
  background-color: #ffffff;
}

.item-detail-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #ffffff;
}

/* 内容容器 - 为底部导航栏留出空间 */
.detail-content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 20rpx;
  margin-bottom: 0;
}

.image-gallery {
  background-color: white;
  padding: 12rpx;
}

.main-image-container {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background: linear-gradient(135deg, #f8fafc 0%, #eef2f7 100%);
  border-radius: 12rpx;
}

.main-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #f8fafc;
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.urgent-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background-color: #f97316;
  color: white;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
}

.image-counter {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.image-nav {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 0 12rpx;
  transform: translateY(-50%);
}

.nav-btn {
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1f2937;
}

.thumbnail-strip {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.thumbnail {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #eef2f7;
  background: linear-gradient(135deg, #f8fafc 0%, #eef2f7 100%);
}

.thumbnail image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #f8fafc;
}

.thumbnail-active {
  border-color: #10b981;
}

.title-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
}

.title-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  flex: 1;
  line-height: 1.4;
}

.action-buttons {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.share-btn,
.like-btn,
.collect-btn {
  font-size: 32rpx;
  color: #64748b;
  transition: transform 0.2s;
}

.share-icon-image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.9;
}

.share-btn:active,
.like-btn:active,
.collect-btn:active {
  transform: scale(1.1);
}

.tags-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.tag-sell {
  background-color: #d1fae5;
  color: #10b981;
}

.tag-exchange {
  background-color: #fff7ed;
  color: #ea580c;
}

.tag-verified {
  background-color: #f8fafc;
  color: #475569;
}

.price-section {
  margin-bottom: 12rpx;
}

.price {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
}

.exchange-info {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 4rpx;
}

.exchange-label {
  font-size: 28rpx;
  color: #6b7280;
  white-space: nowrap;
  flex-shrink: 0;
}

.exchange-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ea580c;
  word-break: break-all;
}

.info-row {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #475569;
}

.distance-tag {
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.distance-tag.near {
  background-color: #ECFDF5;
  color: #10B981;
}

.distance-tag.remote {
  background-color: #FEF3C7;
  color: #D97706;
}

.tags-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eef2f7;
}

.tags-list {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag-item {
  padding: 8rpx 16rpx;
  background-color: #f8fafc;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #475569;
}

.description-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.report-btn {
  padding: 6rpx 12rpx;
  background-color: #fee2e2;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #dc2626;
  font-weight: 600;
}

.description-text {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.seller-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.seller-card {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.seller-avatar {
  width: 48rpx;
  height: 48rpx;
  background-color: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.seller-info {
  flex: 1;
}

.seller-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.seller-name .tag-verified {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
}

.verified-badge {
  color: #10b981;
  font-weight: 700;
  margin-left: 4rpx;
}

.seller-stats {
  font-size: 22rpx;
  color: #9ca3af;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.seller-arrow {
  font-size: 24rpx;
  color: #9ca3af;
  margin-left: 12rpx;
}

/* 安全提示 - 移到联系方式前面 */
.safety-section {
  background-color: #fffbeb;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 2rpx solid #fbbf24;
  box-shadow: 0 1rpx 2rpx rgba(217, 119, 6, 0.08);
}

.safety-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx;
  background-color: #fef3c7;
  border-radius: 8rpx;
  border-left: 4rpx solid #f59e0b;
}

.safety-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #b45309;
}

.safety-toggle {
  font-size: 22rpx;
  color: #b45309;
}

.safety-details {
  margin-top: 12rpx;
  padding: 12rpx;
  background-color: #fef3c7;
  border-radius: 8rpx;
  border-left: 4rpx solid #f59e0b;
}

.safety-item {
  font-size: 25rpx;
  color: #b45309;
  padding: 8rpx 0;
  line-height: 1.5;
}

/* 联系方式 */
.contact-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.contact-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.contact-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

.contact-action {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 600;
}

.login-prompt {
  margin-top: 12rpx;
  padding: 16rpx;
  background-color: #f3f4f6;
  border-radius: 8rpx;
  text-align: center;
  cursor: pointer;
  transition: background-color 0.2s;
}

.login-prompt:hover {
  background-color: #e5e7eb;
}

.login-prompt-text {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 600;
}

/* 交易地点 */
.location-section {
  background-color: white;
  padding: 16rpx;
  margin-top: 12rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
}

.map-container-wrapper {
  margin-top: 12rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #e5e7eb;
}

.map-container {
  width: 100%;
  height: 300rpx;
  background-color: #f3f4f6;
}

.location-info {
  margin-top: 12rpx;
  padding: 12rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.location-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.location-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.distance-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  background-color: #d1fae5;
  border-radius: 16rpx;
  cursor: pointer;
  transition: background-color 0.2s;
}

.distance-badge:hover {
  background-color: #a7f3d0;
}

.distance-text {
  font-size: 22rpx;
  color: #10b981;
  font-weight: 600;
}

.distance-icon {
  font-size: 22rpx;
  color: #10b981;
}

.location-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

.map-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e5e7eb;
}

.map-action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
  cursor: pointer;
  transition: background-color 0.2s;
}

.map-action-btn:hover {
  background-color: #f3f4f6;
}

.map-action-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.map-action-text {
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 600;
}

/* 举报按钮样式 */
.seller-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.seller-actions .report-btn {
  padding: 8rpx;
  border-radius: 8rpx;
  background-color: #fee2e2;
  color: #dc2626;
  font-size: 24rpx;
  cursor: pointer;
  transition: background-color 0.2s;
}

.seller-actions .report-btn:hover {
  background-color: #fecaca;
}


