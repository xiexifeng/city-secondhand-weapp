<!--pages/item-detail/item-detail.wxml-->
<view class="item-detail-container">
  <!-- 内容容器 -->
  <view class="detail-content">
    <!-- 图片轮播 -->
    <view class="image-gallery">
      <view class="main-image-container">
        <image 
          class="main-image" 
          src="{{item.images[currentImageIndex]}}"
          mode="aspectFill"
          lazy-load="true"
        />
        <view wx:if="{{item.urgent}}" class="urgent-badge">急</view>
        <view class="image-counter">
          {{currentImageIndex + 1}}/{{item.images.length}}
        </view>
        <view wx:if="{{item.images.length > 1}}" class="image-nav">
          <view class="nav-btn nav-prev" bindtap="handlePrevImage">
            <text>‹</text>
          </view>
          <view class="nav-btn nav-next" bindtap="handleNextImage">
            <text>›</text>
          </view>
        </view>
      </view>

      <view class="thumbnail-strip">
        <view 
          wx:for="{{item.images}}" 
          wx:key="index"
          class="thumbnail {{currentImageIndex === index ? 'thumbnail-active' : ''}}"
          bindtap="handleSelectImage"
          data-index="{{index}}"
        >
          <image src="{{item}}" mode="aspectFill" lazy-load="true" />
        </view>
      </view>
    </view>

    <!-- 标题和价格 -->
    <view class="title-section">
      <view class="title-header">
        <text class="item-title">{{item.title}}</text>
        <view class="action-buttons">
          <view class="share-btn" bindtap="handleShare">
            <image class="share-icon-image" src="/assets/images/share.svg" mode="aspectFit" />
          </view>
          <view class="like-btn {{liked ? 'liked' : ''}}" bindtap="handleLike">
            <text>{{liked ? '❤️' : '🤍'}}</text>
          </view>
          <view class="collect-btn {{collected ? 'collected' : ''}}" bindtap="handleCollect">
            <text>{{collected ? '⭐' : '☆'}}</text>
          </view>
        </view>
      </view>

      <view class="tags-row">
        <view wx:if="{{item.method === 'sell'}}" class="tag tag-sell">人民币出售</view>
      </view>

      <view class="price-section">
        <text class="price">¥{{item.price}}</text>
      </view>

      <view class="info-row">
        <view class="info-item" bindtap="handleNavigate">
          <text class="info-label">📍</text>
          <text class="info-value">{{item.distance}}km</text>
        </view>
        <view class="info-item">
          <text class="info-label">🕐</text>
          <text class="info-value">{{item.time}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">👁️</text>
          <text class="info-value">{{item.stats.views}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">❤️</text>
          <text class="info-value">{{item.stats.likes}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">⭐</text>
          <text class="info-value">{{item.stats.favorites}}</text>
        </view>
      </view>
    </view>

    <!-- 物品标签 -->
    <view wx:if="{{item.tags.length > 0}}" class="tags-section">
      <view class="tags-list">
        <view wx:for="{{item.tags}}" wx:key="*this" class="tag-item">
          {{item}}
        </view>
      </view>
    </view>

    <!-- 描述 -->
    <view class="description-section">
      <text class="section-title">物品描述</text>
      <text class="description-text">{{item.description}}</text>
    </view>

    <!-- 卖家信息 -->
    <view class="seller-section">
      <view class="section-header">
        <text class="section-title">发布者信息</text>
        <view class="report-btn" bindtap="handleReport">
          <text>🚩 举报</text>
        </view>
      </view>
      <view class="seller-card" bindtap="handleViewSeller">
        <view class="seller-avatar">{{item.seller.avatar}}</view>
        <view class="seller-info">
          <view class="seller-name">
            {{item.seller.name}}
            <view wx:if="{{item.seller.verified}}" class="tag tag-verified">已实名</view>
          </view>
          <view class="seller-stats">
            <text>发布了 {{item.seller.items}} 件物品</text>
            <text>已转让率: {{item.seller.transferRate}}%</text>
          </view>
        </view>
        <view class="seller-actions">
          <view class="seller-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- 安全提示 -->
    <view class="safety-section">
      <view class="safety-header" bindtap="handleToggleSafetyDetails">
        <text class="safety-title">🛡️ 防骗提醒</text>
        <text class="safety-toggle">{{showSafetyDetails ? '▼' : '▶'}}</text>
      </view>
      <view wx:if="{{showSafetyDetails}}" class="safety-details">
        <view class="safety-item">• 勿相信任何要求预付款的交易，包括定金、押金等</view>
        <view class="safety-item">• 见面交易，当面验货，当面付款，不要远程交易</view>
        <view class="safety-item">• 如遇可疑情况，请立即举报，平台会进行处理</view>
        <view class="safety-item">• 警惕虚假身份认证，核实卖家真实信息</view>
        <view class="safety-item">• 不要点击陌生链接，防止信息泄露</view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="contact-section">
      <text class="section-title">联系方式</text>
      
      <!-- 登录状态 -->
      <view wx:if="{{isLoggedIn}}">
        <view class="contact-item" bindtap="handleContactWechat">
          <view class="contact-icon">💬</view>
          <view class="contact-info">
            <text class="contact-label">微信</text>
            <text class="contact-value">{{item.contact.wechat}}</text>
          </view>
          <view class="contact-action">复制</view>
        </view>
        <view class="contact-item" bindtap="handleContactPhone">
          <view class="contact-icon">☎️</view>
          <view class="contact-info">
            <text class="contact-label">电话</text>
            <text class="contact-value">{{item.contact.phone}}</text>
          </view>
          <view class="contact-action">拨打</view>
        </view>
      </view>
      
      <!-- 未登录状态 -->
      <view wx:else>
        <view class="contact-item">
          <view class="contact-icon">💬</view>
          <view class="contact-info">
            <text class="contact-label">微信</text>
            <text class="contact-value">*******123</text>
          </view>
          <view class="contact-action">登录查看</view>
        </view>
        <view class="contact-item">
          <view class="contact-icon">☎️</view>
          <view class="contact-info">
            <text class="contact-label">电话</text>
            <text class="contact-value">138****8000</text>
          </view>
          <view class="contact-action">登录查看</view>
        </view>
        <view class="login-prompt" bindtap="navigateToLogin">
          <view class="login-prompt-text">🔐 登录后查看完整联系方式</view>
        </view>
      </view>
    </view>

    <!-- 交易地点 - 使用原生map组件 -->
    <view class="location-section">
      <text class="section-title">交易地点</text>
      <view class="location-info">
        <view class="location-header">
          <text class="location-label">详细地址</text>
          <view class="distance-badge" bindtap="handleNavigate">
            <text class="distance-text">距您{{item.distance}}km</text>
            <text class="distance-icon">📍</text>
          </view>
        </view>
        <text class="location-value">{{item.location.address}}</text>
      </view>
      <view class="map-container-wrapper">
        <map 
          id="detail-map"
          class="map-container"
          latitude="{{item.location.latitude}}"
          longitude="{{item.location.longitude}}"
          scale="15"
          markers="{{markers}}"
          show-location="true"
        ></map>
      </view>
    </view>
  </view>
  <!-- 底部间距 -->
  <view class="bottom-spacing"></view>

  <!-- 举报表单组件 -->
  <report-form 
    visible="{{showReportModal}}" 
    item="{{item}}" 
    bind:close="closeReportModal"
  />

</view>