page {
  background-color: #f3f4f6;
}

.privacy-settings-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

/* Settings List */
.settings-list {
  background-color: white;
  margin-top: 16rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.setting-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  display: block;
}

.setting-description {
  font-size: 24rpx;
  color: var(--text-color-secondary);
  display: block;
}

/* Toggle Switch */
.toggle-switch {
  width: 48rpx;
  height: 28rpx;
  background-color: #d1d5db;
  border-radius: 14rpx;
  position: relative;
  cursor: pointer;
  transition: background-color 0.3s ease;
  margin-left: 16rpx;
}

.toggle-switch.active {
  background-color: #10b981;
}

.toggle-slider {
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  width: 24rpx;
  height: 24rpx;
  background-color: white;
  border-radius: 50%;
  transition: left 0.3s ease;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.toggle-switch.active .toggle-slider {
  left: 22rpx;
}

/* Tips */
.tips-section {
  background-color: #fef3c7;
  border-left: 4rpx solid var(--warning-color);
  padding: 16rpx;
  margin: 16rpx;
  border-radius: 8rpx;
}

.tips-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #92400e;
  margin-bottom: 12rpx;
}

.tips-item {
  display: block;
  font-size: 22rpx;
  color: #92400e;
  margin-bottom: 8rpx;
}

/* Button */
.btn-group {
  padding: 16rpx;
}

.btn {
  width: 100%;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: #10b981;
  color: white;
}

.btn-primary:active {
  background-color: #059669;
  transform: scale(0.98);
}
