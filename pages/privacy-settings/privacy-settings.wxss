page {
  background-color: #f9fafb;
}

.privacy-settings-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f9fafb;
  padding-bottom: 100rpx;
}

/* Settings List */
.settings-list {
  background-color: white;
  margin: 16rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 3rpx rgba(15, 23, 42, 0.05);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.setting-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
}

.setting-description {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

/* Toggle Switch */
.toggle-switch {
  width: 48rpx;
  height: 28rpx;
  background-color: #d1d5db;
  border-radius: 14rpx;
  position: relative;
  transition: background-color 0.3s ease;
  margin-left: 16rpx;
}

.toggle-switch.active {
  background-color: #10b981;
}

.toggle-slider {
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  width: 24rpx;
  height: 24rpx;
  background-color: white;
  border-radius: 50%;
  transition: left 0.3s ease;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.toggle-switch.active .toggle-slider {
  left: 22rpx;
}

/* Tips */
.tips-section {
  background-color: #fef3c7;
  border-left: 4rpx solid #f59e0b;
  border: 1rpx solid #fcd34d;
  padding: 16rpx;
  margin: 16rpx;
  border-radius: 8rpx;
  box-shadow: 0 1rpx 2rpx rgba(217, 119, 6, 0.08);
}

.tips-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #92400e;
  margin-bottom: 12rpx;
}

.tips-item {
  display: block;
  font-size: 22rpx;
  color: #92400e;
  margin-bottom: 8rpx;
}

/* Button */
.btn-group {
  padding: 16rpx;
}

.btn {
  width: 100%;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: #10b981;
  color: white;
}

.btn-primary:active {
  background-color: #059669;
  transform: scale(0.98);
}
