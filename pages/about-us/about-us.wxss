page {
  background-color: #f3f4f6;
}

.about-us-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f3f4f6;
  padding-bottom: 100rpx;
}

/* Header */
.header {
  background-color: white;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-arrow {
  font-size: 32rpx;
  color: #0ea5e9;
  font-weight: bold;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

/* Content */
.content {
  flex: 1;
  padding: 24rpx 16rpx;
}

/* Logo Section */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background-color: white;
  border-radius: 12rpx;
}

.logo {
  font-size: 64rpx;
}

.app-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
}

.version {
  font-size: 22rpx;
  color: var(--text-color-secondary);
}

/* Section */
.section {
  background-color: white;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

.section-content {
  display: block;
  font-size: 24rpx;
  color: var(--text-color-secondary);
  line-height: 1.6;
}

/* Features List */
.features-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.feature-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.feature-text {
  font-size: 24rpx;
  color: var(--text-color);
}

/* Contact List */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 24rpx;
  color: var(--text-color-secondary);
}

.contact-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-color);
}

/* Link Item */
.link-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.link-item:last-child {
  border-bottom: none;
}

.link-text {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
}

.link-arrow {
  font-size: 24rpx;
  color: #d1d5db;
}

/* Copyright */
.copyright {
  text-align: center;
  padding: 24rpx 16rpx;
  font-size: 22rpx;
  color: #9ca3af;
}
