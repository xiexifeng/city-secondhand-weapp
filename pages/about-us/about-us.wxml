<!--pages/about-us/about-us.wxml-->
<view class="about-us-container">
  <!-- Header -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-arrow">‹</text>
      <text class="header-title">关于我们</text>
    </view>
  </view>

  <!-- Content -->
  <view class="content">
    <!-- Logo Section -->
    <view class="logo-section">
      <text class="logo">🏪</text>
      <text class="app-name">同城二手</text>
      <text class="version">v1.0.0</text>
    </view>

    <!-- About -->
    <view class="section">
      <text class="section-title">关于我们</text>
      <text class="section-content">
        同城二手是一个专业的本地二手物品交易平台，致力于为用户提供安全、便捷、高效的交易体验。我们连接买家和卖家，让闲置物品得到更好的利用。
      </text>
    </view>

    <!-- Mission -->
    <view class="section">
      <text class="section-title">我们的使命</text>
      <text class="section-content">
        通过建立信任的交易平台，让每一个闲置物品都能找到新的主人，促进资源的循环利用，为社区创造更多价值。
      </text>
    </view>

    <!-- Features -->
    <view class="section">
      <text class="section-title">主要功能</text>
      <view class="features-list">
        <view class="feature-item">
          <text class="feature-icon">📱</text>
          <text class="feature-text">本地交易 - 同城用户快速交易</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">🔒</text>
          <text class="feature-text">安全保障 - 实名认证和交易保护</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">💬</text>
          <text class="feature-text">即时沟通 - 快速联系和协商</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">⭐</text>
          <text class="feature-text">信用评价 - 透明的用户评价体系</text>
        </view>
      </view>
    </view>

    <!-- Contact -->
    <view class="section">
      <text class="section-title">联系我们</text>
      <view class="contact-list">
        <view class="contact-item">
          <text class="contact-label">邮箱</text>
          <text class="contact-value">support@secondhand.com</text>
        </view>
        <view class="contact-item">
          <text class="contact-label">电话</text>
          <text class="contact-value">400-123-4567</text>
        </view>
        <view class="contact-item">
          <text class="contact-label">地址</text>
          <text class="contact-value">北京市朝阳区CBD</text>
        </view>
      </view>
    </view>

    <!-- Links -->
    <view class="section">
      <view class="link-item" bindtap="navigateTo" data-page="terms">
        <text class="link-text">使用条款</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="link-item" bindtap="navigateTo" data-page="privacy">
        <text class="link-text">隐私政策</text>
        <text class="link-arrow">›</text>
      </view>
    </view>

    <!-- Copyright -->
    <view class="copyright">
      <text>© 2024 同城二手. All rights reserved.</text>
    </view>
  </view>
</view>
